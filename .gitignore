# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# logs
/logs

# pm2
.pm2
pids
*.pid
*.seed
*.pid.lock

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma
.env*.local
.claude/settings.local.json

# Uploaded files (persistent storage, not in git)
/public/uploads/*
!/public/uploads/.gitkeep
.claude/settings.json
.claude/settings.local.json
.claude/worktrees/
.mcp.json

# docs/ — track .md / .html documentation; ignore generated screenshots
# and the interview-prep file. Previously this section had an overly
# broad `docs/*` rule that silently blocked new docs from being added
# (the redundant `docs/ARCHITECTURE.md` + `docs/HANDOVER.md` lines were
# no-op attempts to whitelist back). Replaced with targeted ignores.
docs/TECHNICAL_INTERVIEW_QA.md
docs/screenshots/
docs/screenshots.zip

# Terraform — anywhere in the repo (belt-and-braces; also gitignored in infra/dr/)
*.tfstate
*.tfstate.*
*.tfstate.backup
terraform.tfvars
*.auto.tfvars
.terraform/
test-results/
playwright-report/
.playwright-mcp/
*.docx
*.xlsx

# Playwright local-verification scratch screenshots (not in repo)
cert-*.png
.playwright-mcp/

# pdfjs-dist worker — copied into public/pdfjs/ by scripts/copy-pdfjs-worker.mjs
# (runs from postinstall). Don't commit the binary; it's regenerated on every
# install + build, so stays in lockstep with the installed pdfjs-dist version.
/public/pdfjs/pdf.worker.min.mjs

# Claude Code runtime state — scheduled wakeup lockfile etc.
.claude/scheduled_tasks.lock
eventsair-introspect-output.txt
