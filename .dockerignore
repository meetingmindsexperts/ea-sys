# Version control
.git
.gitignore

# Environment files
.env
.env.*
!.env.example

# Build artifacts & dependencies (rebuilt inside container)
node_modules
.next

# Logs & debug
logs/
npm-debug.log*

# Documentation — INCLUDED in image (was previously excluded). The
# in-dashboard docs viewer at /admin/docs walks the filesystem at
# runtime and needs these files present. The image-size cost is small
# (~1-2 MB) and the docs are SUPER_ADMIN-gated so they're not exposed
# to end users. If you ever drop the /admin/docs route, restore these
# lines:
#   docs/
#   *.md

# CI/CD & deploy configs (not needed in image)
.github/
deploy/

# scripts/ is deliberately INCLUDED in the image (July 22, 2026). The box has
# no host Node — everything runs in containers — so operator scripts
# (add-tenant-domain, backfills, reconciles) are run via
# `docker exec ea-sys-worker npx tsx scripts/<name>.ts`. Excluding scripts/
# here silently reduced Dockerfile.worker's `COPY scripts ./scripts` to the
# single whitelisted file, making every ops script unrunnable in prod
# (discovered during the Phase-0 tenant-domain seeding). Size cost: ~200 KB.

# Docker configs (not needed inside the image)
docker/
docker-compose*.yml

# Development & testing (not needed in production image)
__tests__/
vitest.config.*
.claude/
.vscode/
.idea/

# Uploaded files (bind-mounted at runtime, not baked into image)
public/uploads/

# Misc
ecosystem.config.js
