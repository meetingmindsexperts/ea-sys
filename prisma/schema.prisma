  createdAt      DateTime @default(now())

  promoCode    PromoCode    @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  registration Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@index([promoCodeId])
  @@index([email])
}

// ==================== SCHEDULED COMMUNICATIONS ====================

enum ScheduledEmailStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
  CANCELLED
}

model ScheduledEmail {
  id             String @id @default(cuid())
  eventId        String
  organizationId String
  createdById    String

  recipientType String // "speakers" | "registrations" | "reviewers" | "abstracts"
  emailType     String // matches bulkEmailSchema.emailType values
  customSubject String?
  customMessage String?  @db.Text
  attachments   Json? // [{ name, content (base64), contentType }]
  filters       Json? // { status?, ticketTypeId? }
  // Explicitly-selected recipient ids (the "send to selected" path). Empty
  // array = filter-based send (resolve recipients at fire time). Lets the
  // immediate-send route queue selected-recipient sends without losing the
  // selection — the worker passes these through to executeBulkEmail.
  recipientIds  String[] @default([])
  // Recipient ids already successfully emailed by a run of this send. Appended
  // per-batch by the worker; on a re-run (retry after a crash) executeBulkEmail
  // skips these so a partial send resumes instead of re-emailing everyone who
  // already received it. Empty for a fresh send. (Review H1.)
  emailedKeys   String[] @default([])

  scheduledFor DateTime
  status       ScheduledEmailStatus @default(PENDING)
  /// Ownership nonce stamped by the PENDING→PROCESSING claim (review C1,
  /// July 16 2026). Heartbeat + completion/failure writes are conditioned on
  /// status AND this token, so a zombie sender (swept FAILED mid-outage, then
  /// Retry'd and re-claimed by another worker) can no longer mark the
  /// re-claimed row SENT with its own counts — `status = PROCESSING` alone
  /// proves liveness, not ownership. Cleared on retry; overwritten per claim.
  claimToken   String?
  sentAt       DateTime?
  successCount Int?
  failureCount Int?
  totalCount   Int?
  lastError    String?              @db.Text
  retryCount   Int                  @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event        Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User         @relation(fields: [createdById], references: [id])

  @@index([status, scheduledFor])
  @@index([eventId, status])
}

// ==================== MCP OAUTH 2.1 (RFC 7591 DCR + PKCE) ====================

model McpOAuthClient {
  id                      String              @id @default(cuid())
  clientId                String              @unique
  clientSecretHash        String?
  clientName              String?
  redirectUris            String[]
  grantTypes              String[]            @default(["authorization_code", "refresh_token"])
  tokenEndpointAuthMethod String              @default("none")
  scope                   String              @default("mcp")
  rateLimitTier           ApiKeyRateLimitTier @default(NORMAL)
  createdAt               DateTime            @default(now())

  authCodes    McpOAuthAuthCode[]
  accessTokens McpOAuthAccessToken[]

  @@index([clientId])
}

model McpOAuthAuthCode {
  id                  String   @id @default(cuid())
  codeHash            String   @unique
  clientId            String
  userId              String
  organizationId      String
  codeChallenge       String
  codeChallengeMethod String   @default("S256")
  redirectUri         String
  scope               String   @default("mcp")
  expiresAt           DateTime
  createdAt           DateTime @default(now())

  client McpOAuthClient @relation(fields: [clientId], references: [clientId], onDelete: Cascade)
  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([userId])
  @@index([expiresAt])
}

model McpOAuthAccessToken {
  id             String    @id @default(cuid())
  tokenHash      String    @unique
  refreshHash    String?   @unique
  clientId       String
  userId         String
  organizationId String
  scope          String    @default("mcp")
  expiresAt      DateTime
  revokedAt      DateTime?
  lastUsedAt     DateTime?
  createdAt      DateTime  @default(now())

  client McpOAuthClient @relation(fields: [clientId], references: [clientId], onDelete: Cascade)
  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([userId])
  @@index([expiresAt])
}

// ==================== EVENT STATS (denormalized read model) ====================

model EventStats {
  id                     String   @id @default(cuid())
  eventId                String   @unique
  registrationsByStatus  Json     @default("{}")
  registrationsByPayment Json     @default("{}")
  totalRegistrations     Int      @default(0)
  checkedInCount         Int      @default(0)
  speakersByStatus       Json     @default("{}")
  totalSpeakers          Int      @default(0)
  agreementsSigned       Int      @default(0)
  abstractsByStatus      Json     @default("{}")
  totalSessions          Int      @default(0)
  totalTracks            Int      @default(0)
  computedAt             DateTime @default(now())
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

// ==================== EMAIL LOG (per-send audit) ====================

enum EmailLogEntityType {
  REGISTRATION
  SPEAKER
  CONTACT
  USER
  OTHER
}

enum EmailLogStatus {
  SENT
  FAILED
}

model EmailLog {
  id                String              @id @default(cuid())
  organizationId    String?
  eventId           String?
  entityType        EmailLogEntityType?
  entityId          String?
  to                String
  cc                String?
  bcc               String?
  subject           String
  templateSlug      String?
  provider          String
  providerMessageId String?
  status            EmailLogStatus
  errorMessage      String?             @db.Text
  // Final rendered HTML of the sent email — audit copy, populated only for
  // opt-in senders (certificate deliveries; see EmailLogContext.storeBody).
  htmlBody          String?             @db.Text
  triggeredByUserId String?
  createdAt         DateTime            @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  event        Event?        @relation(fields: [eventId], references: [id], onDelete: SetNull)
  triggeredBy  User?         @relation(fields: [triggeredByUserId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([organizationId])
  @@index([eventId])
  @@index([to])
  @@index([createdAt])
}

// ── Dinner RSVP ────────────────────────────────────────────────────
// A gala/dinner program for an event. Each event day can have its own
// dinner (Day 1 Dinner, Day 2 Gala, …). Each invitee gets ONE
// personalized token link that covers ALL the event's dinners, and
// answers a per-dinner checkbox (+ per-dinner guest count) plus a
// single dietary note. Docs: docs/DINNER_RSVP.md.

enum RsvpStatus {
  PENDING // invited, not yet responded
  RESPONDED // submitted the form (attending ≥0 dinners)
}

model RsvpDinner {
  id           String    @id @default(cuid())
  eventId      String
  name         String
  dinnerAt     DateTime
  location     String?
  description  String?   @db.Text
  rsvpDeadline DateTime?
  sortOrder    Int       @default(0)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  event     Event                @relation(fields: [eventId], references: [id], onDelete: Cascade)
  responses RsvpDinnerResponse[]

  @@index([eventId])
}

model RsvpInvite {
  id             String     @id @default(cuid())
  eventId        String
  token          String     @unique
  inviteeName    String
  inviteeEmail   String
  // Soft references (no FK) to the person's Registration/Speaker facet,
  // if the invitee was picked from an existing record. The invite keeps
  // its own name/email snapshot, so a dangling id is harmless.
  registrationId String?
  speakerId      String?
  dietary        String?    @db.Text
  status         RsvpStatus @default(PENDING)
  respondedAt    DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  event     Event                @relation(fields: [eventId], references: [id], onDelete: Cascade)
  responses RsvpDinnerResponse[]

  @@unique([eventId, inviteeEmail])
  @@index([eventId])
  @@index([eventId, status])
}

model RsvpDinnerResponse {
  id         String   @id @default(cuid())
  inviteId   String
  dinnerId   String
  attending  Boolean  @default(false)
  guestCount Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  invite RsvpInvite @relation(fields: [inviteId], references: [id], onDelete: Cascade)
  dinner RsvpDinner @relation(fields: [dinnerId], references: [id], onDelete: Cascade)

  @@unique([inviteId, dinnerId])
  @@index([dinnerId])
  @@index([inviteId])
}

// ── Worker job runs ────────────────────────────────────────────────
// One row per background-worker tick (written by withJobLock). Powers
// the Infra / Ops "Cron / Jobs" card — did each cron run, when, did it
// fail. Successful ticks log at debug (skipped by SystemLog), so this
// persisted record is the reliable "last good run" source. Pruned to
// 14 days by the hourly oauth-cleanup job. Docs: docs/INFRA_OPS.md.

enum JobRunStatus {
  OK
  FAILED
}

/// One row per refund ATTEMPT, persisted BEFORE the Stripe call (crash-safety
/// for money movement — review finding H4/H5, July 10 2026). The row id is the
/// Stripe idempotency key (`refund-attempt-{id}`) and rides in the Stripe
/// refund's metadata, so a crashed/ambiguous attempt can always be verified
/// against Stripe and reconciled by the sweep in
/// src/lib/refund-reconciliation.ts:
///   PENDING   — booked in refundedAmount; Stripe call in flight (or process
///               died before it — the sweep resolves which).
///   SUCCEEDED — money moved (or manual refund recorded).
///   FAILED    — Stripe refused and the booking was rolled back.
///   UNKNOWN   — Stripe errored AND verification failed; booking kept, sweep
///               retries verification until it can resolve.
model RefundAttempt {
  id                    String              @id @default(cuid())
  registrationId        String
  registration          Registration        @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  /// Payment row targeted (plain column, no FK — audit/ops record).
  paymentId             String?
  /// Stripe payment intent the refund runs against; null for manual/offline.
  stripePaymentIntentId String?
  amount                Decimal             @db.Decimal(10, 2)
  refundedBefore        Decimal             @db.Decimal(10, 2)
  refundedAfter         Decimal             @db.Decimal(10, 2)
  /// Whether the registration was flipped to REFUNDED by this attempt's
  /// booking — the sweep needs it to roll the flip back on a failed attempt.
  flippedToRefunded     Boolean             @default(false)
  kind                  String // "stripe" | "manual"
  status                RefundAttemptStatus @default(PENDING)
  stripeRefundId        String?
  error                 String?
  source                String?
  issuedByUserId        String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  @@index([registrationId])
  @@index([status, createdAt])
}

enum RefundAttemptStatus {
  PENDING
  SUCCEEDED
  FAILED
  UNKNOWN
}

model JobRun {
  id         String       @id @default(cuid())
  job        String
  startedAt  DateTime
  finishedAt DateTime
  status     JobRunStatus
  durationMs Int
  error      String?      @db.Text
  createdAt  DateTime     @default(now())

  @@index([job, startedAt])
  @@index([startedAt])
}

// ═══════════════════════════════════════════════════════════════════════════
// CRM MODULE
//
// Bounded module — see docs/CRM_MODULE_PLAN.md §7.0 ("independent module,
// shared runtime"). Every model is Crm*-prefixed so the schema reads as one
// distinct block; code lives under src/crm/, routes under /api/crm/*, pages
// under /(dashboard)/crm/*. src/crm/ may import core; core NEVER imports
// src/crm/ (enforced by an ESLint import-boundary rule, not by discipline).
//
// Primary use case (locked, §9): SPONSOR / EXHIBITOR SALES PIPELINE. The
// CrmDeal.eventId link is the whole point — "Abbott → BRIDGES 2026 → Gold →
// $40k → Negotiation" is a join no off-the-shelf CRM can do against our data.
// ═══════════════════════════════════════════════════════════════════════════

enum CrmDealStatus {
  OPEN
  WON
  LOST
}

enum CrmTaskStatus {
  OPEN
  DONE
}

/// Contact lifecycle (locked, §9). Nullable on Contact — existing contacts stay
/// null, so this is additive and needs no backfill. NOTE: an account lapses, a
/// person doesn't — "lapsed sponsor" is deliberately NOT a value here; it is a
/// deal/company query ("won last year, nothing open this year").
enum CrmLifecycleStage {
  LEAD
  ENGAGED
  CUSTOMER
  CHAMPION
}

enum CrmActivityType {
  NOTE
  CALL
  MEETING
}

/// Which CRM entity a CrmActivity row is about. Polymorphic (entityType +
/// entityId) rather than four FK columns — one timeline table across all four
/// record types, same shape as the core AuditLog.
enum CrmActivityEntity {
  DEAL
  COMPANY
  CONTACT
  TASK
}

/// The CRM change log — the "detailed activity log" surfaced in every detail
/// sheet. SYSTEM-generated (create / edit-with-field-diffs / archive / restore /
/// stage-move / won / lost / contact-linked …), distinct from CrmNote which is a
/// human-written note/call/meeting.
///
/// This is the CRM's OWN audit store, not the core AuditLog: it is org-scoped
/// (trivial tenant-safe reads), it stores before→after field diffs purpose-built
/// for a timeline, and — critically — it is actually READ in the UI, which the
/// core AuditLog's CRM rows never were. One writer feeds it (recordCrmActivity),
/// so the trail can't drift between callers.
model CrmActivity {
  id             String       @id @default(cuid())
  organizationId String
  org            Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  entityType CrmActivityEntity
  entityId   String

  /// CREATE | UPDATE | ARCHIVE | RESTORE | STAGE_MOVE | WON | LOST |
  /// CONTACT_ADDED | CONTACT_REMOVED | COMPLETE | REOPEN | LINK_EVENT_CONTACT | …
  action  String
  /// { source, changes?: { field: { from, to } }, ...snapshot }. `dealValue` keys
  /// here are stripped for money-blind callers by the same FINANCIAL_KEYS redactor
  /// the board uses.
  changes Json?

  /// Nullable + SetNull: an activity row outlives the user who caused it (a rep
  /// leaves, their account is deleted — the trail must not vanish with them).
  actorId String?
  actor   User?   @relation("CrmActivityActor", fields: [actorId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([organizationId, entityType, entityId, createdAt])
  @@index([organizationId, createdAt])
}

/// Reusable CRM email templates — the org's editable starting points for the
/// sponsor blast + per-deal send. Org-wide shared (any CRM writer edits the same
/// set); seeded on first use from the built-in constants. Soft-delete via
/// archivedAt (a picker lists non-archived; the send substitutes {{tokens}} in the
/// body at send time — the template just pre-fills subject + body).
model CrmEmailTemplate {
  id             String       @id @default(cuid())
  organizationId String
  org            Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name    String
  subject String
  /// HTML body fragment (no greeting/signature — the send pipeline adds those).
  body    String @db.Text

  sortOrder  Int       @default(0)
  archivedAt DateTime?

  createdById String?
  createdBy   User?   @relation("CrmEmailTemplateCreator", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Makes the first-use seed race-safe (CRM review H1): with the unique in place,
  // the seed's createMany({ skipDuplicates: true }) actually skips when two
  // concurrent first-loads both pass the count===0 fast-path — without it,
  // skipDuplicates is a no-op and both writers insert the full template set.
  @@unique([organizationId, name])
  @@index([organizationId, sortOrder])
}

/// In-house vs out-sourced — the sourcing axis, distinct from the functional category.
enum CrmProductSource {
  IN_HOUSE
  OUTSOURCED
}

/// The org's product/service catalog (seeded from CrmProductSeed, then editable).
/// `category` is the FUNCTIONAL group (Content, Sponsorship, …) — the deal-facing
/// category; `source` is the In-House/Out-Sourced axis. `price` is the catalog list
/// price (AED) that pre-fills a deal line item — the line price is set on the deal.
model CrmProduct {
  id             String       @id @default(cuid())
  organizationId String
  org            Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name     String
  sku      String?
  category String
  source   CrmProductSource @default(IN_HOUSE)
  price    Decimal          @default(0) @db.Decimal(12, 2)
  currency String           @default("AED")
  priceIncludesTax Boolean  @default(false)

  sortOrder  Int       @default(0)
  archivedAt DateTime?

  createdById String?
  createdBy   User?   @relation("CrmProductCreator", fields: [createdById], references: [id], onDelete: SetNull)

  dealLines CrmDealProduct[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Unique SKU per org — makes the seed idempotent under a concurrent first-load
  // (the second seed's createMany skipDuplicates skips the SKU-collisions) AND stops
  // manual duplicate SKUs. `sku` is nullable, so Postgres treats multiple NULL-SKU
  // products as distinct — manual products without a SKU are unaffected.
  @@unique([organizationId, sku])
  @@index([organizationId, category, sortOrder])
}

/// A product on a deal — a line item. The deal's Value stays MANUAL; this is the
/// itemization (products total is informational). `unitPrice` is set on the deal
/// (pre-filled from the catalog list price). name/category/sku are snapshotted at
/// add-time so a later catalog edit never rewrites a deal's line.
model CrmDealProduct {
  id     String  @id @default(cuid())
  dealId String
  deal   CrmDeal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  crmProductId String?
  crmProduct   CrmProduct? @relation(fields: [crmProductId], references: [id], onDelete: SetNull)

  productName String
  category    String
  sku         String?

  unitPrice Decimal @default(0) @db.Decimal(12, 2)
  currency  String  @default("AED")
  quantity  Int     @default(1)

  createdAt DateTime @default(now())

  @@index([dealId])
  @@index([crmProductId])
}

/// First-class Account. Today Contact.organization is a free-text string, which
/// is why "Cleveland Clinic" and "Cleveland Clinic Foundation" are two things.
///
/// `nameKey` is the trimmed+lowercased name and carries the unique index;
/// `name` is the display form. This is deliberate: the contacts review (H2,
/// July 14 2026) found that a CASE-SENSITIVE unique index plus writers that
/// don't normalize mints two rows for one entity — and then the downstream
/// sync silently mirrors only one of the pair. Normalizing in the index rather
/// than trusting every writer to lowercase makes that bug unrepresentable.
model CrmCompany {
  id             String       @id @default(cuid())
  organizationId String
  org            Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name     String
  nameKey  String // trimmed + lowercased — the dedup key, see note above
  industry String? // pharma | hospital | society | agency | …
  website  String?
  country  String?
  city     String?
  notes    String? @db.Text

  /// Set when created via fuzzy match (e.g. "Cleveland Clinic" vs "Cleveland
  /// Clinic Foundation") so finance can merge later. Advisory — never blocks.
  needsReview Boolean @default(false)

  contacts CrmContact[]
  deals    CrmDeal[]
  tasks    CrmTask[]
  notes_   CrmNote[]


  /// External-system provenance (Freshsales CSV import). `externalId` is the
  /// source system's record id — the upsert key that makes RE-importing a fresh
  /// export converge instead of duplicate. `lastImportedAt` powers the conflict
  /// rule: a row edited in EA-SYS after its last import wins over the CSV.
  externalSource String?
  externalId     String?
  lastImportedAt DateTime?

  /// Soft delete. Set = archived (hidden from lists/board/reports, restorable).
  /// We never hard-delete a CRM record: the row and its CrmActivity trail survive
  /// so "who archived this account, and when" stays answerable.
  archivedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, nameKey])
  @@unique([organizationId, externalSource, externalId])
  @@index([organizationId])
}

/// Org-configurable pipeline (locked, §9). A TABLE, not an enum — sales will
/// change its mind, and that must be a row edit rather than a migration against
/// a live production DB. Seeded per-org with:
///   Prospect → Contacted → Proposal → Negotiation → Won → Lost
/// The two terminal stages are flagged isTerminal.
///
/// SECURITY: stageId becomes user-supplied input on every deal write and every
/// kanban drag, so it is an IDOR surface — always bind it to the caller's org
/// before use.
model CrmPipelineStage {
  id             String       @id @default(cuid())
  organizationId String
  org            Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name       String
  sortOrder  Int
  isTerminal Boolean @default(false)

  /// The business outcome a TERMINAL stage implies (CRM review H3). Stored on the
  /// row, NOT derived from the stage name, so renaming "Won" can never silently
  /// stop drag-to-close/closeDeal() from closing deals. Null on open stages, and
  /// on a custom terminal stage the org hasn't mapped — deals dragged into an
  /// unmapped terminal stage keep their current status rather than having an
  /// outcome invented from the column name.
  terminalOutcome CrmStageOutcome?

  /// Deals are Restrict-protected: you cannot delete a stage that still holds
  /// deals — move them first. Silently vaporising a pipeline column's contents
  /// is not a thing we let an errant click do.
  deals CrmDeal[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Stage names are load-bearing lookup keys (the board, the reconcile planner) —
  // and the unique is what makes the seed's createMany skipDuplicates actually
  // skip under a concurrent first-load (CRM review H1). Case-sensitive; the seed
  // always writes identical strings, so both racers collide as intended.
  @@unique([organizationId, name])
  @@index([organizationId, sortOrder])
}

/// The outcome a terminal CrmPipelineStage maps a deal to. See
/// CrmPipelineStage.terminalOutcome.
enum CrmStageOutcome {
  WON
  LOST
}

/// A sponsorship / exhibitor deal.
///
/// FK deletion policy is chosen so that MONEY HISTORY SURVIVES:
///   company  → Restrict  (can't delete an account that has deals; reassign or
///                         close them first — the BillingAccount precedent)
///   stage    → Restrict  (see CrmPipelineStage)
///   event    → SetNull   (event deletion is already a heavy cascade; the deal
///                         is revenue history and must outlive it)
///   contact  → SetNull
///   owner    → SetNull   (see the ownerId note below)
///
/// `ownerId` is NULLABLE and SetNull, deviating from the original blueprint
/// sketch (which had it required). Reason: users DO get deleted here (temp
/// accounts are a routine flow). A required owner with Restrict would make
/// deleting a deal-owning organizer fail with a raw P2003 from an unrelated
/// core route — and teaching that core route about CRM would violate the
/// one-way import rule. An unowned deal is visible, recoverable and
/// reassignable; a blocked user-delete or an orphaned FK is neither.
model CrmDeal {
  id             String       @id @default(cuid())
  organizationId String
  org            Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name String // "Abbott — BRIDGES 2026 Gold"

  companyId String?
  company   CrmCompany? @relation(fields: [companyId], references: [id], onDelete: Restrict)

  /// A deal involves SEVERAL people at the account — the rep, marketing,
  /// procurement. A single contactId cannot model that, so the link is a join
  /// table carrying each person's role on this deal.
  contacts CrmDealContact[]

  /// THE differentiator — the deal↔event join (§9 decision 1).
  eventId String?
  event   Event?  @relation(fields: [eventId], references: [id], onDelete: SetNull)

  /// Finance-gated: `dealValue` is in FINANCIAL_KEYS so the existing
  /// redactFinancialFields() machinery hides it from MEMBER unchanged (§9 d4).
  ///
  /// Named `dealValue`, NOT `value`, deliberately: redactFinancialFields() is a
  /// recursive strip-by-key-name, and `value` already occurs in unrelated
  /// payload shapes (survey free-text answers). A bare `value` in FINANCIAL_KEYS
  /// would blank those for MEMBER — a new feature breaking a shipped one.
  dealValue Decimal? @db.Decimal(12, 2)
  currency  String   @default("USD")

  stageId String
  stage   CrmPipelineStage @relation(fields: [stageId], references: [id], onDelete: Restrict)

  ownerId String?
  owner   User?   @relation("CrmDealOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  expectedClose DateTime?
  status        CrmDealStatus @default(OPEN)
  wonAt         DateTime?
  lostAt        DateTime?
  lostReason    String?

  /// Set once the won deal has been pushed to Event.settings.sponsors[] (§7.6),
  /// so the "create sponsor entry" button is offered exactly once.
  sponsorSyncedAt DateTime?

  tasks    CrmTask[]
  notes    CrmNote[]
  products CrmDealProduct[]


  /// External-system provenance (Freshsales CSV import). `externalId` is the
  /// source system's record id — the upsert key that makes RE-importing a fresh
  /// export converge instead of duplicate. `lastImportedAt` powers the conflict
  /// rule: a row edited in EA-SYS after its last import wins over the CSV.
  externalSource String?
  externalId     String?
  lastImportedAt DateTime?

  /// Soft delete — see CrmCompany.archivedAt. Archived deals drop out of the board,
  /// the reports and the CSV export (pipeline totals must not count a dead deal).
  archivedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, externalSource, externalId])
  @@index([organizationId, status])
  @@index([organizationId, stageId])
  @@index([eventId])
  @@index([companyId])
  @@index([ownerId, status])
}

model CrmTask {
  id             String       @id @default(cuid())
  organizationId String
  org            Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  title       String
  description String?   @db.Text
  dueAt       DateTime?

  ownerId String?
  owner   User?   @relation("CrmTaskOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  crmContactId String?
  crmContact   CrmContact? @relation(fields: [crmContactId], references: [id], onDelete: Cascade)

  companyId String?
  company   CrmCompany? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  dealId String?
  deal   CrmDeal? @relation(fields: [dealId], references: [id], onDelete: Cascade)

  status CrmTaskStatus @default(OPEN)

  /// Reminder job (worker/jobs/crm-reminders.ts, every 5 min):
  ///   remindAt <= now AND remindedAt IS NULL AND status = OPEN
  /// `remindedAt` is the idempotency stamp — written in the same claim as the
  /// send so a crash mid-tick can't double-email. Served by the plain @@index on
  /// remindAt below (a regular index, not a partial one).
  remindAt   DateTime?
  remindedAt DateTime?

  completedAt DateTime?
  createdById String?

  /// Soft delete — see CrmCompany.archivedAt.
  archivedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, status, dueAt])
  @@index([ownerId, status])
  @@index([dealId])
  @@index([crmContactId])
  @@index([remindAt])
}

/// Manual activity log — the "we actually called them" record that no automated
/// sync can produce. Merges into the existing activity-feed.ts builder so a
/// person's emails + edits + notes render as ONE timeline.
///
/// `authorId` is SetNull: the note body is history and must outlive the author's
/// account. A note attributed to "(deleted user)" is fine; a vanished note isn't.
model CrmNote {
  id             String       @id @default(cuid())
  organizationId String
  org            Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  body         String          @db.Text
  activityType CrmActivityType @default(NOTE)

  authorId String?
  author   User?   @relation("CrmNoteAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  crmContactId String?
  crmContact   CrmContact? @relation(fields: [crmContactId], references: [id], onDelete: Cascade)

  companyId String?
  company   CrmCompany? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  dealId String?
  deal   CrmDeal? @relation(fields: [dealId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, createdAt])
  @@index([crmContactId, createdAt])
  @@index([companyId, createdAt])
  @@index([dealId, createdAt])
}

/// Cross-process state for the admin-alert pipeline.
///
/// Dedup used to be an in-memory Map inside admin-alert.ts. With blue-green
/// (two web slots) plus the worker container, that is THREE independent maps —
/// so every error fingerprint could page the operator up to 3x — and each one
/// is wiped on container restart, which means a deploy during an ongoing
/// incident re-opens the floodgates. Postgres gives us one shared, durable,
/// atomically-claimable dedup state.
///
/// Three kinds of row share this table, distinguished by `key`:
///   - "logger:<module>:<msg>"  a single error fingerprint.
///       lastSentAt = when we last emailed about it
///       counter    = occurrences suppressed since that email
///   - "__ceiling__"            the global alerts-per-hour budget.
///       windowStartedAt = start of the current hour bucket
///       counter         = alerts sent inside it
///   - "__silence__"            operator-set maintenance window.
///       silencedUntil = alerts are suppressed until this instant
model AlertState {
  key             String    @id
  lastSentAt      DateTime  @default(now())
  windowStartedAt DateTime  @default(now())
  counter         Int       @default(0)
  silencedUntil   DateTime?
  updatedAt       DateTime  @updatedAt
}

/// Role a person plays ON A SPECIFIC DEAL. The same rep can be PRIMARY on one
/// deal and merely INFLUENCER on another, which is why it lives on the join and
/// not on CrmContact.
enum CrmDealContactRole {
  PRIMARY
  PROCUREMENT
  MARKETING
  TECHNICAL
  INFLUENCER
  OTHER
}

/// A BUSINESS contact — a pharma rep, an exhibitor's sales manager, a society
/// liaison, procurement. The person our team actually negotiates with.
///
/// ─── WHY THIS IS NOT THE `Contact` TABLE ─────────────────────────────────────
/// `Contact` is the EVENT contact store: HCPs — doctors, nurses, allied health.
/// Every row in it is mirrored to the external `contacts_centralv1` table by
/// `contacts-central-sync`, which selects with NO where-clause, and that table
/// feeds `mailchimp_*`. Putting an Abbott sales rep in `Contact` would therefore
/// market to them as if they were a doctor.
///
/// That leak could have been prevented with a discriminator column plus a filter
/// in every reader. It is prevented HERE by structure instead: the central sync
/// reads `Contact`, and a `CrmContact` is not a `Contact`, so a rep CANNOT reach
/// the HCP marketing mirror by someone forgetting a `where` clause. Same
/// reasoning as `nameKey` carrying the unique index rather than trusting every
/// writer to lowercase.
///
/// ─── THE PERSON WHO IS BOTH ──────────────────────────────────────────────────
/// An Abbott rep often also attends the conference (they staff the booth). That
/// person is ONE human with two hats, and EA-SYS's identity rule is "one person,
/// one record" — so we do NOT duplicate them. `contactId` POINTS at their event
/// `Contact` row when one exists. Linked, not copied. Exactly the shape of
/// `Speaker.sourceRegistrationId`.
model CrmContact {
  id             String       @id @default(cuid())
  organizationId String
  org            Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  /// The account they work for. Nullable — you often meet the person before you
  /// know which entity is actually signing.
  companyId String?
  company   CrmCompany? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  firstName String
  lastName  String

  /// Display form. `emailKey` (trim+lowercase) carries the unique index — the
  /// same structural dedup as CrmCompany.nameKey, so "S.Khan@abbott.com" and
  /// "s.khan@abbott.com" cannot become two people.
  email    String
  emailKey String

  jobTitle String? // "Regional Medical Affairs Lead"
  phone    String?
  country  String?
  notes    String? @db.Text

  lifecycleStage CrmLifecycleStage?

  /// Set ONLY when this business contact is also in the event contact store
  /// (i.e. they attend). SetNull, so deleting the event contact doesn't destroy
  /// the CRM record of the person we're negotiating with.
  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  deals    CrmDealContact[]
  tasks    CrmTask[]
  crmNotes CrmNote[]


  /// External-system provenance (Freshsales CSV import). `externalId` is the
  /// source system's record id — the upsert key that makes RE-importing a fresh
  /// export converge instead of duplicate. `lastImportedAt` powers the conflict
  /// rule: a row edited in EA-SYS after its last import wins over the CSV.
  externalSource String?
  externalId     String?
  lastImportedAt DateTime?

  /// Soft delete — see CrmCompany.archivedAt.
  archivedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, emailKey])
  @@unique([organizationId, externalSource, externalId])
  @@index([organizationId])
  @@index([companyId])
  @@index([contactId])
}

/// Deal ↔ person, with the role that person plays on THIS deal.
///
/// A sponsorship deal is not negotiated with one human: there is the rep who
/// wants it, the marketing lead who owns the budget, and the procurement officer
/// who can veto it. Modelling that as a single `contactId` on the deal loses the
/// two people who actually decide whether it closes.
model CrmDealContact {
  id String @id @default(cuid())

  dealId String
  deal   CrmDeal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  crmContactId String
  crmContact   CrmContact @relation(fields: [crmContactId], references: [id], onDelete: Cascade)

  role CrmDealContactRole @default(PRIMARY)

  createdAt DateTime @default(now())

  @@unique([dealId, crmContactId])
  @@index([crmContactId])
}
