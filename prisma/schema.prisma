generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==================== CORE ENTITIES ====================

model Organization {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  logo         String?
  primaryColor String?  @map("primary_color")
  settings     Json     @default("{}")
  // Billing/Company info (for invoice "From" section)
  companyName      String?
  companyAddress   String?   @db.Text
  companyCity      String?
  companyState     String?
  companyZipCode   String?
  companyCountry   String?
  companyPhone     String?
  companyEmail     String?
  taxId            String?
  invoicePrefix    String?   @default("INV")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  users           User[]
  events          Event[]
  contacts        Contact[]
  apiKeys         ApiKey[]
  mediaFiles      MediaFile[]
  invoices        Invoice[]
  scheduledEmails ScheduledEmail[]
  emailLogs       EmailLog[]
}

model User {
  id             String    @id @default(cuid())
  organizationId String?
  email          String    @unique
  passwordHash   String
  firstName      String
  lastName       String
  role           UserRole  @default(ORGANIZER)
  specialty      String?
  emailVerified    DateTime?
  termsAcceptedAt  DateTime?
  termsAcceptedIp  String?
  image            String?
  emailSignature   String?   @db.Text
  createdAt        DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization    Organization?    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  speakers        Speaker[]
  registrations   Registration[]
  auditLogs       AuditLog[]
  accounts        Account[]
  sessions        AuthSession[]
  notifications   Notification[]
  mediaFiles      MediaFile[]
  deviceTokens    DeviceToken[]
  scheduledEmails ScheduledEmail[]
  mcpOAuthAuthCodes    McpOAuthAuthCode[]
  mcpOAuthAccessTokens McpOAuthAccessToken[]
  abstractReviewerOf        AbstractReviewer[]         @relation("ReviewerOnAbstracts")
  assignedAbstractReviewers AbstractReviewer[]         @relation("AssignedAbstractReviewers")
  abstractSubmissions       AbstractReviewSubmission[] @relation("UserAbstractSubmissions")
  triggeredEmailLogs        EmailLog[]

  @@index([organizationId])
  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model AuthSession {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  ORGANIZER
  MEMBER
  REVIEWER
  SUBMITTER
  REGISTRANT
}

enum Title {
  DR
  MR
  MRS
  MS
  PROF
}

enum AttendeeRole {
  ACADEMIA
  ALLIED_HEALTH
  MEDICAL_DEVICES
  PHARMA
  PHYSICIAN
  RESIDENT
  SPEAKER
  STUDENT
  OTHERS
}

model Event {
  id             String      @id @default(cuid())
  organizationId String
  name           String
  slug           String
  description    String?     @db.Text
  startDate      DateTime
  endDate        DateTime
  timezone       String      @default("Asia/Dubai")
  venue          String?
  address        String?
  city           String?
  country        String?
  eventType      EventType?
  tag            String?
  specialty      String?
  code           String?
  status         EventStatus @default(DRAFT)
  settings       Json        @default("{}")
  bannerImage    String?
  footerHtml     String?     @db.Text
  emailHeaderImage String?
  emailFooterHtml  String?   @db.Text
  emailFromAddress String?
  emailFromName    String?
  // Addresses CC'd on every event-scoped email — both automated
  // (registration confirmation, speaker invite, abstract status,
  // bulk email, scheduled email) and manual single-sends from the
  // detail sheets. Empty array = no auto-CC.
  emailCcAddresses String[]  @default([])
  supportEmail           String?
  registrationTermsHtml    String?   @db.Text
  registrationWelcomeHtml  String?   @db.Text
  abstractWelcomeHtml      String?   @db.Text
  abstractTermsHtml        String?   @db.Text
  abstractConfirmationHtml String?   @db.Text
  registrationConfirmationHtml String? @db.Text
  speakerAgreementHtml     String?   @db.Text
  speakerAgreementTemplate Json?
  taxRate                  Decimal?  @db.Decimal(5, 2)
  taxLabel                 String?   @default("VAT")
  bankDetails              String?   @db.Text
  badgeVerticalOffset      Int       @default(0)
  externalId     String?
  externalSource String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ticketTypes    TicketType[]
  registrations  Registration[]
  speakers       Speaker[]
  eventSessions  EventSession[]
  tracks         Track[]
  hotels         Hotel[]
  accommodations Accommodation[]
  abstracts      Abstract[]
  abstractThemes AbstractTheme[]
  reviewCriteria ReviewCriterion[]
  auditLogs      AuditLog[]

  importLogs     ImportLog[]
  emailTemplates EmailTemplate[]
  notifications  Notification[]
  mediaFiles     MediaFile[]
  invoices        Invoice[]
  invoiceCounters InvoiceCounter[]
  zoomMeetings    ZoomMeeting[]
  zoomAttendances ZoomAttendance[]
  promoCodes      PromoCode[]
  scheduledEmails ScheduledEmail[]
  eventStats      EventStats?
  emailLogs       EmailLog[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([status])
  @@index([startDate])
  @@index([externalSource, externalId])
}

enum EventStatus {
  DRAFT
  PUBLISHED
  LIVE
  COMPLETED
  CANCELLED
}

enum EventType {
  CONFERENCE
  WEBINAR
  HYBRID
}

// ==================== REGISTRATION & TICKETING ====================

model TicketType {
  id               String   @id @default(cuid())
  eventId          String
  name             String
  description      String?  @db.Text
  isDefault        Boolean   @default(false)
  isActive         Boolean   @default(true)
  sortOrder        Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Deprecated: kept for migration backward compat, will be removed
  category         String    @default("Standard")
  price            Decimal   @default(0) @db.Decimal(10, 2)
  currency         String    @default("USD")
  quantity         Int       @default(999999)
  soldCount        Int       @default(0)
  maxPerOrder      Int       @default(10)
  salesStart       DateTime?
  salesEnd         DateTime?
  requiresApproval Boolean   @default(false)

  event          Event                @relation(fields: [eventId], references: [id], onDelete: Cascade)
  pricingTiers   PricingTier[]
  registrations  Registration[]
  promoCodeLinks PromoCodeTicketType[]

  @@index([eventId])
  @@index([isActive])
}

model PricingTier {
  id               String    @id @default(cuid())
  ticketTypeId     String
  name             String
  price            Decimal   @default(0) @db.Decimal(10, 2)
  currency         String    @default("USD")
  quantity         Int       @default(999999)
  soldCount        Int       @default(0)
  maxPerOrder      Int       @default(10)
  salesStart       DateTime?
  salesEnd         DateTime?
  isActive         Boolean   @default(true)
  requiresApproval Boolean   @default(false)
  sortOrder        Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  ticketType    TicketType     @relation(fields: [ticketTypeId], references: [id], onDelete: Cascade)
  registrations Registration[]

  @@unique([ticketTypeId, name])
  @@index([ticketTypeId])
  @@index([isActive])
}

model Attendee {
  id               String        @id @default(cuid())
  title            Title?
  role             AttendeeRole?
  email            String
  additionalEmail  String?
  firstName        String
  lastName         String
  organization     String?
  jobTitle         String?
  phone            String?
  photo            String?
  city             String?
  state            String?
  zipCode          String?
  country          String?
  bio              String?       @db.Text
  specialty        String?
  customSpecialty  String?
  registrationType String?
  tags             String[]      @default([])
  dietaryReqs      String?
  associationName  String?
  memberId         String?
  studentId        String?
  studentIdExpiry  DateTime?
  customFields     Json          @default("{}")
  externalId       String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  registrations Registration[]

  @@index([email])
}

model Registration {
  id             String             @id @default(cuid())
  eventId        String
  ticketTypeId   String?
  pricingTierId  String?
  attendeeId     String
  userId         String?
  serialId       Int?
  status         RegistrationStatus @default(PENDING)
  paymentStatus  PaymentStatus      @default(UNPAID)
  qrCode         String?            @unique
  dtcmBarcode    String?            @unique
  badgeType      String?
  referrer       String?
  utmSource      String?
  utmMedium      String?
  utmCampaign    String?
  checkedInAt    DateTime?
  notes          String?            @db.Text
  // Billing details (for invoices/tax)
  taxNumber          String?
  billingFirstName   String?
  billingLastName    String?
  billingEmail       String?
  billingPhone       String?
  billingAddress     String?
  billingCity        String?
  billingState       String?
  billingZipCode     String?
  billingCountry     String?
  // Promo code discount
  promoCodeId        String?
  discountAmount     Decimal?       @db.Decimal(10, 2)
  originalPrice      Decimal?       @db.Decimal(10, 2)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  event           Event               @relation(fields: [eventId], references: [id], onDelete: Cascade)
  ticketType      TicketType?         @relation(fields: [ticketTypeId], references: [id])
  pricingTier     PricingTier?        @relation(fields: [pricingTierId], references: [id])
  attendee        Attendee            @relation(fields: [attendeeId], references: [id])
  user            User?               @relation(fields: [userId], references: [id])
  promoCode       PromoCode?          @relation(fields: [promoCodeId], references: [id])
  payments        Payment[]
  accommodation   Accommodation?
  invoices        Invoice[]
  promoRedemption PromoCodeRedemption?
  zoomAttendances ZoomAttendance[]

  @@unique([eventId, serialId])
  @@index([eventId])
  @@index([eventId, status])
  @@index([eventId, ticketTypeId])
  @@index([pricingTierId])
  @@index([attendeeId])
  @@index([userId])
  @@index([promoCodeId])
  @@index([status])
  @@index([qrCode])
}

enum RegistrationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  WAITLISTED
  CHECKED_IN
}

enum PaymentStatus {
  UNPAID
  PENDING
  PAID
  COMPLIMENTARY
  REFUNDED
  FAILED
  UNASSIGNED
}

model Payment {
  id                String        @id @default(cuid())
  registrationId    String
  amount            Decimal       @db.Decimal(10, 2)
  currency          String        @default("USD")
  stripePaymentId   String?       @unique
  stripeCustomerId  String?
  status            PaymentStatus @default(PENDING)
  receiptUrl        String?
  // Card / payment instrument details captured from the Stripe PaymentIntent
  // at settlement time. `cardBrand` + `cardLast4` appear on the post-payment
  // Invoice PDF and the registration Billing panel so organizers can
  // reconcile. `paymentMethodType` is Stripe's top-level classification
  // (`card`, `bank_transfer`, `sepa_debit`, etc.). `paidAt` is the authoritative
  // settlement timestamp — `createdAt` records when we inserted the row,
  // which drifts from the actual capture moment under webhook retries.
  cardBrand         String?
  cardLast4         String?
  paymentMethodType String?
  paidAt            DateTime?
  metadata          Json          @default("{}")
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  registration Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  invoice      Invoice?

  @@index([registrationId])
  @@index([stripePaymentId])
}

// ==================== SPEAKER MANAGEMENT ====================

model Speaker {
  id               String        @id @default(cuid())
  eventId          String
  userId           String?
  title            Title?
  role             AttendeeRole?
  email            String
  additionalEmail  String?
  firstName        String
  lastName         String
  bio              String?       @db.Text
  organization     String?
  jobTitle         String?
  phone            String?
  website          String?
  photo            String?
  city             String?
  state            String?
  zipCode          String?
  country          String?
  specialty        String?
  customSpecialty  String?
  registrationType String?
  tags             String[]      @default([])
  socialLinks      Json          @default("{}")
  status           SpeakerStatus @default(INVITED)
  externalId       String?
  agreementAcceptedAt    DateTime?
  agreementAcceptedIp    String?
  agreementAcceptedBy    String?
  agreementTextSnapshot  String?  @db.Text
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  event         Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user          User?            @relation(fields: [userId], references: [id])
  sessions      SessionSpeaker[]
  topicSpeakers TopicSpeaker[]
  abstracts     Abstract[]
  accommodation Accommodation?

  @@unique([eventId, email])
  @@index([eventId])
  @@index([status])
}

enum SpeakerStatus {
  INVITED
  CONFIRMED
  DECLINED
  CANCELLED
}

model Abstract {
  id               String            @id @default(cuid())
  eventId          String
  speakerId        String
  title            String
  content          String            @db.Text
  trackId          String?
  themeId          String?
  specialty        String?
  presentationType PresentationType?
  status           AbstractStatus    @default(SUBMITTED)
  managementToken  String?           @unique
  submittedAt      DateTime          @default(now())
  reviewedAt       DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  event        Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  speaker      Speaker        @relation(fields: [speakerId], references: [id], onDelete: Cascade)
  track        Track?         @relation(fields: [trackId], references: [id])
  theme        AbstractTheme? @relation(fields: [themeId], references: [id])
  eventSession EventSession?
  sessionTopic SessionTopic?
  reviewers    AbstractReviewer[]
  submissions  AbstractReviewSubmission[]

  @@index([eventId])
  @@index([speakerId])
  @@index([status])
}

model AbstractReviewer {
  id           String               @id @default(cuid())
  abstractId   String
  userId       String
  assignedAt   DateTime             @default(now())
  assignedById String
  role         AbstractReviewerRole @default(SECONDARY)
  conflictFlag Boolean              @default(false)

  abstract    Abstract                   @relation(fields: [abstractId], references: [id], onDelete: Cascade)
  user        User                       @relation("ReviewerOnAbstracts", fields: [userId], references: [id], onDelete: Cascade)
  assignedBy  User                       @relation("AssignedAbstractReviewers", fields: [assignedById], references: [id])
  submissions AbstractReviewSubmission[]

  @@unique([abstractId, userId])
  @@index([abstractId])
  @@index([userId])
}

model AbstractReviewSubmission {
  id                 String             @id @default(cuid())
  abstractId         String
  reviewerUserId     String
  abstractReviewerId String?
  criteriaScores     Json?
  overallScore       Int?
  reviewNotes        String?            @db.Text
  recommendedFormat  RecommendedFormat?
  confidence         Int?
  submittedAt        DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  abstract         Abstract          @relation(fields: [abstractId], references: [id], onDelete: Cascade)
  reviewer         User              @relation("UserAbstractSubmissions", fields: [reviewerUserId], references: [id], onDelete: Cascade)
  abstractReviewer AbstractReviewer? @relation(fields: [abstractReviewerId], references: [id], onDelete: SetNull)

  @@unique([abstractId, reviewerUserId])
  @@index([abstractId])
  @@index([reviewerUserId])
}

model AbstractTheme {
  id        String     @id @default(cuid())
  eventId   String
  name      String
  sortOrder Int        @default(0)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  event     Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  abstracts Abstract[]

  @@unique([eventId, name])
  @@index([eventId])
}

model ReviewCriterion {
  id        String   @id @default(cuid())
  eventId   String
  name      String
  weight    Int
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
}

enum AbstractStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  ACCEPTED
  REJECTED
  REVISION_REQUESTED
  WITHDRAWN
}

enum PresentationType {
  ORAL
  POSTER
  VIDEO
  WORKSHOP
}

enum RecommendedFormat {
  ORAL
  POSTER
  NEITHER
}

enum AbstractReviewerRole {
  PRIMARY
  SECONDARY
  CONSULTING
}

// ==================== SESSIONS & SCHEDULE ====================

model Track {
  id          String   @id @default(cuid())
  eventId     String
  name        String
  description String?  @db.Text
  color       String   @default("#3B82F6")
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  event         Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventSessions EventSession[]
  abstracts     Abstract[]

  @@index([eventId])
}

model EventSession {
  id          String        @id @default(cuid())
  eventId     String
  abstractId  String?       @unique
  trackId     String?
  name        String
  description String?       @db.Text
  startTime   DateTime
  endTime     DateTime
  location    String?
  capacity    Int?
  status      SessionStatus @default(SCHEDULED)
  externalId  String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  event    Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  abstract Abstract?        @relation(fields: [abstractId], references: [id])
  track    Track?           @relation(fields: [trackId], references: [id])
  speakers    SessionSpeaker[]
  topics      SessionTopic[]
  zoomMeeting ZoomMeeting?
  zoomAttendances ZoomAttendance[]

  @@index([eventId])
  @@index([startTime])
  @@index([trackId])
}

enum SessionStatus {
  DRAFT
  SCHEDULED
  LIVE
  COMPLETED
  CANCELLED
}

enum SessionRole {
  SPEAKER
  MODERATOR
  CHAIRPERSON
  PANELIST
}

model SessionSpeaker {
  sessionId String
  speakerId String
  role      SessionRole @default(SPEAKER)

  session EventSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  speaker Speaker      @relation(fields: [speakerId], references: [id], onDelete: Cascade)

  @@id([sessionId, speakerId])
}

model SessionTopic {
  id         String   @id @default(cuid())
  sessionId  String
  abstractId String?  @unique
  title      String
  sortOrder  Int      @default(0)
  duration   Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  session  EventSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  abstract Abstract?      @relation(fields: [abstractId], references: [id])
  speakers TopicSpeaker[]

  @@index([sessionId])
}

model TopicSpeaker {
  topicId   String
  speakerId String

  topic   SessionTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  speaker Speaker      @relation(fields: [speakerId], references: [id], onDelete: Cascade)

  @@id([topicId, speakerId])
}

// ==================== ACCOMMODATION ====================

model Hotel {
  id           String   @id @default(cuid())
  eventId      String
  name         String
  address      String?
  description  String?  @db.Text
  contactEmail String?
  contactPhone String?
  stars        Int?
  images       Json     @default("[]")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  event     Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  roomTypes RoomType[]

  @@index([eventId])
}

model RoomType {
  id            String   @id @default(cuid())
  hotelId       String
  name          String
  description   String?  @db.Text
  pricePerNight Decimal  @db.Decimal(10, 2)
  currency      String   @default("USD")
  capacity      Int      @default(2)
  totalRooms    Int
  bookedRooms   Int      @default(0)
  amenities     Json     @default("[]")
  images        Json     @default("[]")
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  hotel          Hotel           @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  accommodations Accommodation[]

  @@index([hotelId])
}

model Accommodation {
  id              String              @id @default(cuid())
  eventId         String
  registrationId  String?             @unique
  speakerId       String?             @unique
  roomTypeId      String
  checkIn         DateTime
  checkOut        DateTime
  guestCount      Int                 @default(1)
  specialRequests String?             @db.Text
  status          AccommodationStatus @default(PENDING)
  totalPrice      Decimal             @db.Decimal(10, 2)
  currency        String              @default("USD")
  confirmationNo  String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  event        Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  registration Registration? @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  speaker      Speaker?      @relation(fields: [speakerId], references: [id], onDelete: Cascade)
  roomType     RoomType     @relation(fields: [roomTypeId], references: [id])

  @@index([eventId])
  @@index([roomTypeId])
  @@index([status])
}

enum AccommodationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  CHECKED_IN
  CHECKED_OUT
}

// ==================== CONTACT STORE ====================

model Contact {
  id               String        @id @default(cuid())
  organizationId   String
  org              Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  title            Title?
  role             AttendeeRole?
  email            String
  additionalEmail  String?
  firstName        String
  lastName         String
  organization     String?
  jobTitle         String?
  bio              String?       @db.Text
  specialty        String?
  customSpecialty  String?
  registrationType String?
  phone            String?
  photo            String?
  city             String?
  state            String?
  zipCode          String?
  country          String?
  associationName  String?
  memberId         String?
  studentId        String?
  studentIdExpiry  DateTime?
  tags             String[]      @default([])
  eventIds         String[]      @default([])
  notes            String?       @db.Text
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@unique([organizationId, email])
  @@index([organizationId])
}

// ==================== MEDIA ====================

model MediaFile {
  id             String       @id @default(cuid())
  organizationId String
  eventId        String?
  uploadedById   String
  filename       String
  url            String
  mimeType       String
  size           Int
  createdAt      DateTime     @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  event          Event?       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  uploadedBy     User         @relation(fields: [uploadedById], references: [id])

  @@index([organizationId])
  @@index([eventId])
}

// ==================== AUDIT & LOGGING ====================

model AuditLog {
  id         String   @id @default(cuid())
  eventId    String?
  userId     String?
  action     String
  entityType String
  entityId   String
  changes    Json     @default("{}")
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  event Event? @relation(fields: [eventId], references: [id], onDelete: SetNull)
  user  User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([eventId])
  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model SystemLog {
  id        String   @id @default(cuid())
  level     String   // error, warn, info, debug
  module    String   // api, auth, database, events, middleware
  message   String   @db.Text
  timestamp DateTime @default(now())

  @@index([timestamp])
  @@index([level])
  @@index([module])
}

// ==================== IMPORT LOGS ====================

model ImportLog {
  id             String   @id @default(cuid())
  eventId        String
  userId         String
  source         String   // "eventsair" | "csv"
  entityType     String   // "contacts" | "registrations" | "speakers" | "sessions"
  totalProcessed Int
  totalCreated   Int
  totalSkipped   Int
  totalErrors    Int
  skippedDetails Json     @default("[]") // [{ email, reason }]
  errors         Json     @default("[]") // string[]
  createdAt      DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([createdAt])
}

// ==================== EMAIL TEMPLATES ====================

model EmailTemplate {
  id          String   @id @default(cuid())
  eventId     String
  slug        String   // e.g. "registration-confirmation", "speaker-invitation"
  name        String   // Human-readable: "Registration Confirmation"
  subject     String   // Subject line with {{variables}}
  htmlContent String   @db.Text // HTML body with {{variables}}
  textContent String?  @db.Text // Plain text fallback
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, slug])
  @@index([eventId])
}

// ==================== NOTIFICATIONS ====================

model Notification {
  id        String   @id @default(cuid())
  userId    String
  eventId   String?
  type      String   // REGISTRATION, PAYMENT, ABSTRACT, REVIEW, CHECK_IN
  title     String
  message   String
  link      String?  // URL to navigate to when clicked
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event? @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

// ==================== MOBILE PUSH NOTIFICATIONS ====================

model DeviceToken {
  id        String   @id @default(cuid())
  userId    String
  platform  String   // "ios" or "android"
  pushToken String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, pushToken])
  @@index([userId])
}

// ==================== API KEYS ====================

model ApiKey {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  keyHash        String    @unique
  prefix         String
  createdAt      DateTime  @default(now())
  lastUsedAt     DateTime?
  expiresAt      DateTime?
  isActive       Boolean   @default(true)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([isActive])
}

// ==================== INVOICES & RECEIPTS ====================

model Invoice {
  id               String        @id @default(cuid())
  organizationId   String
  eventId          String
  registrationId   String
  paymentId        String?       @unique

  type             InvoiceType
  invoiceNumber    String        @unique
  sequenceNumber   Int

  status           InvoiceStatus @default(DRAFT)

  issueDate        DateTime      @default(now())
  dueDate          DateTime?
  paidDate         DateTime?

  // Financial snapshot (frozen at creation time)
  subtotal         Decimal       @db.Decimal(10, 2)
  discountCode     String?
  discountAmount   Decimal       @default(0) @db.Decimal(10, 2)
  taxRate          Decimal?      @db.Decimal(5, 2)
  taxLabel         String?
  taxAmount        Decimal       @default(0) @db.Decimal(10, 2)
  total            Decimal       @db.Decimal(10, 2)
  currency         String        @default("USD")

  paymentMethod    String?
  paymentReference String?
  parentInvoiceId  String?

  notes            String?       @db.Text
  sentAt           DateTime?
  sentTo           String?

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  organization     Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  event            Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  registration     Registration  @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  payment          Payment?      @relation(fields: [paymentId], references: [id])
  parentInvoice    Invoice?      @relation("CreditNotes", fields: [parentInvoiceId], references: [id])
  creditNotes      Invoice[]     @relation("CreditNotes")

  @@unique([eventId, sequenceNumber, type])
  @@index([eventId])
  @@index([registrationId])
  @@index([status])
  @@index([issueDate])
}

model InvoiceCounter {
  id               String      @id @default(cuid())
  eventId          String
  type             InvoiceType
  lastSequence     Int         @default(0)

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, type])
}

enum InvoiceType {
  INVOICE
  RECEIPT
  CREDIT_NOTE
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
  REFUNDED
}

// ==================== ZOOM INTEGRATION ====================

model ZoomMeeting {
  id             String            @id @default(cuid())
  sessionId      String            @unique
  eventId        String
  zoomMeetingId  String
  meetingType    ZoomMeetingType
  joinUrl        String
  startUrl       String?           @db.Text
  passcode       String?
  duration       Int?
  status         ZoomMeetingStatus @default(CREATED)
  isRecurring    Boolean           @default(false)
  recurrenceType Int?
  occurrences    Json?
  zoomResponse   Json?
  // Live streaming (RTMP → MediaMTX → HLS)
  liveStreamEnabled Boolean       @default(false)
  streamKey         String?       // unique key for RTMP path
  streamStatus      StreamStatus  @default(IDLE)
  // Cloud recording (fetched by /api/cron/webinar-recordings post-event)
  recordingUrl         String?          @db.Text
  recordingPassword    String?
  recordingDownloadUrl String?          @db.Text
  recordingDuration    Int?             // seconds
  recordingFetchedAt   DateTime?
  recordingStatus      RecordingStatus  @default(NOT_REQUESTED)
  // Attendance tracking (fetched by /api/cron/webinar-attendance post-event)
  lastAttendanceSyncAt DateTime?
  // Engagement (polls + Q&A, fetched alongside attendance post-event)
  lastEngagementSyncAt DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  session     EventSession      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  event       Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  attendances ZoomAttendance[]
  polls       WebinarPoll[]
  questions   WebinarQuestion[]

  @@index([eventId])
  @@index([zoomMeetingId])
  @@index([recordingStatus])
  @@index([lastAttendanceSyncAt])
}

// ── Webinar polls (fetched from Zoom's /report/webinars/{id}/polls) ──
model WebinarPoll {
  id             String   @id @default(cuid())
  zoomMeetingId  String
  zoomPollId     String?  // Zoom's poll id (nullable for imported/legacy rows)
  title          String
  questions      Json     @default("[]")  // [{ name, question_type, answer_details?: [] }]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  zoomMeeting ZoomMeeting           @relation(fields: [zoomMeetingId], references: [id], onDelete: Cascade)
  responses   WebinarPollResponse[]

  @@unique([zoomMeetingId, zoomPollId])
  @@index([zoomMeetingId])
}

// One row per participant per poll submission
model WebinarPollResponse {
  id               String   @id @default(cuid())
  pollId           String
  participantName  String
  participantEmail String?
  answers          Json     @default("{}") // { questionName: answer[] }
  submittedAt      DateTime

  poll WebinarPoll @relation(fields: [pollId], references: [id], onDelete: Cascade)

  @@index([pollId])
}

// ── Webinar Q&A (fetched from Zoom's /report/webinars/{id}/qa) ──
model WebinarQuestion {
  id             String   @id @default(cuid())
  zoomMeetingId  String
  askerName      String
  askerEmail     String?
  question       String   @db.Text
  answer         String?  @db.Text
  answeredByName String?
  askedAt        DateTime

  zoomMeeting ZoomMeeting @relation(fields: [zoomMeetingId], references: [id], onDelete: Cascade)

  @@unique([zoomMeetingId, askerName, askedAt])
  @@index([zoomMeetingId])
}

// ── Per-attendee join/leave records pulled from Zoom's participant report ──
model ZoomAttendance {
  id                 String   @id @default(cuid())
  zoomMeetingId      String
  eventId            String
  sessionId          String
  registrationId     String?               // best-effort match by email
  zoomParticipantId  String?               // Zoom's per-session participant id
  name               String
  email              String?
  joinTime           DateTime
  leaveTime          DateTime?
  durationSeconds    Int                   // sum from Zoom report
  attentivenessScore Int?                  // Zoom returns this for some webinars
  createdAt          DateTime @default(now())

  zoomMeeting  ZoomMeeting   @relation(fields: [zoomMeetingId], references: [id], onDelete: Cascade)
  event        Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  session      EventSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  registration Registration? @relation(fields: [registrationId], references: [id], onDelete: SetNull)

  // A single Zoom participant id can join+leave multiple times; the report
  // returns one row per join/leave segment, so the unique key includes joinTime
  // to keep them distinct without losing the rejoin history.
  @@unique([zoomMeetingId, zoomParticipantId, joinTime])
  @@index([zoomMeetingId])
  @@index([eventId, sessionId])
  @@index([email])
  @@index([registrationId])
}

enum RecordingStatus {
  NOT_REQUESTED  // cloud recording not enabled for this webinar
  PENDING        // webinar ended but recording not yet available
  AVAILABLE      // recording fetched and URL stored
  FAILED         // fetch attempts exhausted
  EXPIRED        // recording fetch window closed (>7 days post-event)
}

enum ZoomMeetingType {
  MEETING
  WEBINAR
  WEBINAR_SERIES
}

enum ZoomMeetingStatus {
  CREATED
  STARTED
  ENDED
  DELETED
}

enum StreamStatus {
  IDLE
  ACTIVE
  ENDED
  ERROR
}

// ==================== PROMO CODES ====================

model PromoCode {
  id               String       @id @default(cuid())
  eventId          String
  code             String
  description      String?      @db.Text
  discountType     DiscountType
  discountValue    Decimal      @db.Decimal(10, 2)
  currency         String?
  maxUses          Int?
  maxUsesPerEmail  Int?         @default(1)
  usedCount        Int          @default(0)
  validFrom        DateTime?
  validUntil       DateTime?
  isActive         Boolean      @default(true)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  event            Event                @relation(fields: [eventId], references: [id], onDelete: Cascade)
  ticketTypes      PromoCodeTicketType[]
  redemptions      PromoCodeRedemption[]
  registrations    Registration[]

  @@unique([eventId, code])
  @@index([eventId])
  @@index([code])
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

model PromoCodeTicketType {
  id           String     @id @default(cuid())
  promoCodeId  String
  ticketTypeId String

  promoCode    PromoCode  @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  ticketType   TicketType @relation(fields: [ticketTypeId], references: [id], onDelete: Cascade)

  @@unique([promoCodeId, ticketTypeId])
  @@index([promoCodeId])
  @@index([ticketTypeId])
}

model PromoCodeRedemption {
  id              String   @id @default(cuid())
  promoCodeId     String
  registrationId  String   @unique
  email           String
  originalPrice   Decimal  @db.Decimal(10, 2)
  discountAmount  Decimal  @db.Decimal(10, 2)
  finalPrice      Decimal  @db.Decimal(10, 2)
  createdAt       DateTime @default(now())

  promoCode       PromoCode    @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  registration    Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@index([promoCodeId])
  @@index([email])
}

// ==================== SCHEDULED COMMUNICATIONS ====================

enum ScheduledEmailStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
  CANCELLED
}

model ScheduledEmail {
  id             String   @id @default(cuid())
  eventId        String
  organizationId String
  createdById    String

  recipientType  String   // "speakers" | "registrations" | "reviewers" | "abstracts"
  emailType      String   // matches bulkEmailSchema.emailType values
  customSubject  String?
  customMessage  String?  @db.Text
  attachments    Json?    // [{ name, content (base64), contentType }]
  filters        Json?    // { status?, ticketTypeId? }

  scheduledFor   DateTime
  status         ScheduledEmailStatus @default(PENDING)
  sentAt         DateTime?
  successCount   Int?
  failureCount   Int?
  totalCount     Int?
  lastError      String?  @db.Text
  retryCount     Int      @default(0)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  event        Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User         @relation(fields: [createdById], references: [id])

  @@index([status, scheduledFor])
  @@index([eventId, status])
}

// ==================== MCP OAUTH 2.1 (RFC 7591 DCR + PKCE) ====================

model McpOAuthClient {
  id                      String   @id @default(cuid())
  clientId                String   @unique
  clientSecretHash        String?
  clientName              String?
  redirectUris            String[]
  grantTypes              String[] @default(["authorization_code", "refresh_token"])
  tokenEndpointAuthMethod String   @default("none")
  scope                   String   @default("mcp")
  createdAt               DateTime @default(now())

  authCodes    McpOAuthAuthCode[]
  accessTokens McpOAuthAccessToken[]

  @@index([clientId])
}

model McpOAuthAuthCode {
  id                  String   @id @default(cuid())
  codeHash            String   @unique
  clientId            String
  userId              String
  organizationId      String
  codeChallenge       String
  codeChallengeMethod String   @default("S256")
  redirectUri         String
  scope               String   @default("mcp")
  expiresAt           DateTime
  createdAt           DateTime @default(now())

  client McpOAuthClient @relation(fields: [clientId], references: [clientId], onDelete: Cascade)
  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([userId])
  @@index([expiresAt])
}

model McpOAuthAccessToken {
  id             String    @id @default(cuid())
  tokenHash      String    @unique
  refreshHash    String?   @unique
  clientId       String
  userId         String
  organizationId String
  scope          String    @default("mcp")
  expiresAt      DateTime
  revokedAt      DateTime?
  lastUsedAt     DateTime?
  createdAt      DateTime  @default(now())

  client McpOAuthClient @relation(fields: [clientId], references: [clientId], onDelete: Cascade)
  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([userId])
  @@index([expiresAt])
}

// ==================== EVENT STATS (denormalized read model) ====================

model EventStats {
  id                     String   @id @default(cuid())
  eventId                String   @unique
  registrationsByStatus  Json     @default("{}")
  registrationsByPayment Json     @default("{}")
  totalRegistrations     Int      @default(0)
  checkedInCount         Int      @default(0)
  speakersByStatus       Json     @default("{}")
  totalSpeakers          Int      @default(0)
  agreementsSigned       Int      @default(0)
  abstractsByStatus      Json     @default("{}")
  totalSessions          Int      @default(0)
  totalTracks            Int      @default(0)
  computedAt             DateTime @default(now())
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

// ==================== EMAIL LOG (per-send audit) ====================

enum EmailLogEntityType {
  REGISTRATION
  SPEAKER
  CONTACT
  USER
  OTHER
}

enum EmailLogStatus {
  SENT
  FAILED
}

model EmailLog {
  id                String              @id @default(cuid())
  organizationId    String?
  eventId           String?
  entityType        EmailLogEntityType?
  entityId          String?
  to                String
  cc                String?
  bcc               String?
  subject           String
  templateSlug      String?
  provider          String
  providerMessageId String?
  status            EmailLogStatus
  errorMessage      String?             @db.Text
  triggeredByUserId String?
  createdAt         DateTime            @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  event        Event?        @relation(fields: [eventId], references: [id], onDelete: SetNull)
  triggeredBy  User?         @relation(fields: [triggeredByUserId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([organizationId])
  @@index([eventId])
  @@index([to])
  @@index([createdAt])
}
