  state                          String?
  zipCode                        String?
  country                        String?
  specialty                      String?
  customSpecialty                String?
  registrationType               String?
  tags                           String[]      @default([])
  socialLinks                    Json          @default("{}")
  status                         SpeakerStatus @default(INVITED)
  externalId                     String?
  agreementAcceptedAt            DateTime?
  agreementAcceptedIp            String?
  agreementAcceptedBy            String?
  agreementTextSnapshot          String?       @db.Text
  // Presenter (abstract-author) agreement — DISTINCT from the faculty speaker
  // agreement above. A person can be both a faculty speaker (agreement*) and an
  // abstract author (presenterAgreement*); the two are accepted independently.
  // Per-author, per-event: one acceptance covers all their abstracts. See
  // src/lib/presenter-agreement.ts.
  presenterAgreementAcceptedAt   DateTime?
  presenterAgreementAcceptedIp   String?
  presenterAgreementAcceptedBy   String?
