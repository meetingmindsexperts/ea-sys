model InvoiceCounter {
  id           String      @id @default(cuid())
  eventId      String
  type         InvoiceType
  lastSequence Int         @default(0)

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, type])
}

// One row per event holding the last-assigned registration serialId.
// Mutated via an atomic upsert+increment (see src/lib/registration-serial.ts)
// so concurrent registrations can't collide on @@unique([eventId, serialId]).
model RegistrationSerialCounter {
  eventId    String @id
  lastSerial Int    @default(0)

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

// Reusable org-scoped payer for "charge to another account" — a doctor's
// hospital, or a pharma/grant covering specific HCPs. Distinct from
// Event.settings.sponsors[] (bulk pre-paid INCLUSIVE deals) and from the
// Registration.billing* block (same payer, different address). Soft-delete
// via isActive; the Registration FK is Restrict so a payer with linked
// registrations can't be hard-deleted out from under them.
model BillingAccount {
  id             String             @id @default(cuid())
  organizationId String
  name           String
  type           BillingAccountType @default(INSTITUTION)
  email          String?
  phone          String?
  contactName    String?
  address        String?
  city           String?
  state          String?
  zipCode        String?
  country        String?
  taxNumber      String?
  notes          String?            @db.Text
  isActive       Boolean            @default(true)
  // True until finance reviews a payer created from the public
  // registration flow (prevents "Cleveland Clinic" vs "cleveland clinic
  // inc" duplicates from going straight into the canonical list).
  needsReview    Boolean            @default(false)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  organization  Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  registrations Registration[]
  events        EventBillingAccount[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

enum BillingAccountType {
  INSTITUTION
  COMPANY
  OTHER
}

// Per-event availability of a BillingAccount. Junction (a.k.a. associative)
// table giving a many-to-many between Event and BillingAccount with SHARED
// IDENTITY — one logical "Cleveland Clinic" payer can be attached to many
// events, but the BillingAccount row is never duplicated. The picker on
// each event filters to the payers attached via this table, so events
// don't see an overflow of every payer in the org.
model EventBillingAccount {
  id               String   @id @default(cuid())
  eventId          String
  billingAccountId String
  addedAt          DateTime @default(now())
  addedByUserId    String?

  event          Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  billingAccount BillingAccount @relation(fields: [billingAccountId], references: [id], onDelete: Cascade)
  addedBy        User?          @relation(fields: [addedByUserId], references: [id], onDelete: SetNull)

  @@unique([eventId, billingAccountId])
  @@index([eventId])
  @@index([billingAccountId])
}

enum InvoiceType {
  INVOICE
  RECEIPT
  CREDIT_NOTE
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
  REFUNDED
}

// ==================== ZOOM INTEGRATION ====================

model ZoomMeeting {
  id                   String            @id @default(cuid())
  sessionId            String            @unique
  eventId              String
  zoomMeetingId        String
  meetingType          ZoomMeetingType
  joinUrl              String
  startUrl             String?           @db.Text
  passcode             String?
  duration             Int?
  status               ZoomMeetingStatus @default(CREATED)
  isRecurring          Boolean           @default(false)
  recurrenceType       Int?
  occurrences          Json?
  zoomResponse         Json?
  // Live streaming (RTMP → MediaMTX → HLS)
  liveStreamEnabled    Boolean           @default(false)
  streamKey            String? // unique key for RTMP path
  streamStatus         StreamStatus      @default(IDLE)
  // Cloud recording (fetched by /api/cron/webinar-recordings post-event)
  recordingUrl         String?           @db.Text
  recordingPassword    String?
  recordingDownloadUrl String?           @db.Text
  recordingDuration    Int? // seconds
  recordingFetchedAt   DateTime?
  recordingStatus      RecordingStatus   @default(NOT_REQUESTED)
  // Attendance tracking (fetched by /api/cron/webinar-attendance post-event)
  lastAttendanceSyncAt DateTime?
  // Engagement (polls + Q&A, fetched alongside attendance post-event)
  lastEngagementSyncAt DateTime?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  session     EventSession      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  event       Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  attendances ZoomAttendance[]
  polls       WebinarPoll[]
  questions   WebinarQuestion[]

  @@index([eventId])
  @@index([zoomMeetingId])
  @@index([recordingStatus])
  @@index([lastAttendanceSyncAt])
}

// ── Webinar polls (fetched from Zoom's /report/webinars/{id}/polls) ──
model WebinarPoll {
  id            String   @id @default(cuid())
  zoomMeetingId String
  zoomPollId    String? // Zoom's poll id (nullable for imported/legacy rows)
  title         String
  questions     Json     @default("[]") // [{ name, question_type, answer_details?: [] }]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  zoomMeeting ZoomMeeting           @relation(fields: [zoomMeetingId], references: [id], onDelete: Cascade)
  responses   WebinarPollResponse[]

  @@unique([zoomMeetingId, zoomPollId])
  @@index([zoomMeetingId])
}

// One row per participant per poll submission
model WebinarPollResponse {
  id               String   @id @default(cuid())
  pollId           String
  participantName  String
  participantEmail String?
  answers          Json     @default("{}") // { questionName: answer[] }
  submittedAt      DateTime

  poll WebinarPoll @relation(fields: [pollId], references: [id], onDelete: Cascade)

  @@index([pollId])
}

// ── Webinar Q&A (fetched from Zoom's /report/webinars/{id}/qa) ──
model WebinarQuestion {
  id             String   @id @default(cuid())
  zoomMeetingId  String
  askerName      String
  askerEmail     String?
  question       String   @db.Text
  answer         String?  @db.Text
  answeredByName String?
  askedAt        DateTime

  zoomMeeting ZoomMeeting @relation(fields: [zoomMeetingId], references: [id], onDelete: Cascade)

  @@unique([zoomMeetingId, askerName, askedAt])
  @@index([zoomMeetingId])
}

// ── Per-attendee join/leave records pulled from Zoom's participant report ──
model ZoomAttendance {
  id                 String    @id @default(cuid())
  zoomMeetingId      String
  eventId            String
  sessionId          String
  registrationId     String? // best-effort match by email
  zoomParticipantId  String? // Zoom's per-session participant id
  name               String
  email              String?
  joinTime           DateTime
  leaveTime          DateTime?
  durationSeconds    Int // sum from Zoom report
  attentivenessScore Int? // Zoom returns this for some webinars
  createdAt          DateTime  @default(now())

  zoomMeeting  ZoomMeeting   @relation(fields: [zoomMeetingId], references: [id], onDelete: Cascade)
  event        Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  session      EventSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  registration Registration? @relation(fields: [registrationId], references: [id], onDelete: SetNull)

  // A single Zoom participant id can join+leave multiple times; the report
  // returns one row per join/leave segment, so the unique key includes joinTime
  // to keep them distinct without losing the rejoin history.
  @@unique([zoomMeetingId, zoomParticipantId, joinTime])
  @@index([zoomMeetingId])
  @@index([eventId, sessionId])
  @@index([email])
  @@index([registrationId])
}

enum RecordingStatus {
  NOT_REQUESTED // cloud recording not enabled for this webinar
  PENDING // webinar ended but recording not yet available
  AVAILABLE // recording fetched and URL stored
  FAILED // fetch attempts exhausted
  EXPIRED // recording fetch window closed (>7 days post-event)
}

enum ZoomMeetingType {
  MEETING
  WEBINAR
  WEBINAR_SERIES
}

enum ZoomMeetingStatus {
  CREATED
  STARTED
  ENDED
  DELETED
}

enum StreamStatus {
  IDLE
  ACTIVE
  ENDED
  ERROR
}

// ==================== PROMO CODES ====================

model PromoCode {
  id              String       @id @default(cuid())
  eventId         String
  code            String
  description     String?      @db.Text
  discountType    DiscountType
  discountValue   Decimal      @db.Decimal(10, 2)
  currency        String?
  maxUses         Int?
  maxUsesPerEmail Int?         @default(1)
  usedCount       Int          @default(0)
  validFrom       DateTime?
  validUntil      DateTime?
  isActive        Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  event         Event                 @relation(fields: [eventId], references: [id], onDelete: Cascade)
  ticketTypes   PromoCodeTicketType[]
  redemptions   PromoCodeRedemption[]
  registrations Registration[]

  @@unique([eventId, code])
  @@index([eventId])
  @@index([code])
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

model PromoCodeTicketType {
  id           String @id @default(cuid())
  promoCodeId  String
  ticketTypeId String

  promoCode  PromoCode  @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  ticketType TicketType @relation(fields: [ticketTypeId], references: [id], onDelete: Cascade)

  @@unique([promoCodeId, ticketTypeId])
  @@index([promoCodeId])
  @@index([ticketTypeId])
}

model PromoCodeRedemption {
  id             String   @id @default(cuid())
  promoCodeId    String
  registrationId String   @unique
  email          String
  originalPrice  Decimal  @db.Decimal(10, 2)
  discountAmount Decimal  @db.Decimal(10, 2)
  finalPrice     Decimal  @db.Decimal(10, 2)
  createdAt      DateTime @default(now())

  promoCode    PromoCode    @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  registration Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@index([promoCodeId])
  @@index([email])
}

// ==================== SCHEDULED COMMUNICATIONS ====================

enum ScheduledEmailStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
  CANCELLED
}

model ScheduledEmail {
  id             String @id @default(cuid())
  eventId        String
  organizationId String
  createdById    String

  recipientType String // "speakers" | "registrations" | "reviewers" | "abstracts"
  emailType     String // matches bulkEmailSchema.emailType values
  customSubject String?
  customMessage String? @db.Text
  attachments   Json? // [{ name, content (base64), contentType }]
  filters       Json? // { status?, ticketTypeId? }

  scheduledFor DateTime
  status       ScheduledEmailStatus @default(PENDING)
  sentAt       DateTime?
  successCount Int?
  failureCount Int?
  totalCount   Int?
  lastError    String?              @db.Text
  retryCount   Int                  @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event        Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User         @relation(fields: [createdById], references: [id])

  @@index([status, scheduledFor])
  @@index([eventId, status])
}

// ==================== MCP OAUTH 2.1 (RFC 7591 DCR + PKCE) ====================

model McpOAuthClient {
  id                      String              @id @default(cuid())
  clientId                String              @unique
  clientSecretHash        String?
  clientName              String?
  redirectUris            String[]
  grantTypes              String[]            @default(["authorization_code", "refresh_token"])
  tokenEndpointAuthMethod String              @default("none")
  scope                   String              @default("mcp")
  rateLimitTier           ApiKeyRateLimitTier @default(NORMAL)
  createdAt               DateTime            @default(now())

  authCodes    McpOAuthAuthCode[]
  accessTokens McpOAuthAccessToken[]

  @@index([clientId])
}

model McpOAuthAuthCode {
  id                  String   @id @default(cuid())
  codeHash            String   @unique
  clientId            String
  userId              String
  organizationId      String
  codeChallenge       String
  codeChallengeMethod String   @default("S256")
  redirectUri         String
  scope               String   @default("mcp")
  expiresAt           DateTime
  createdAt           DateTime @default(now())

  client McpOAuthClient @relation(fields: [clientId], references: [clientId], onDelete: Cascade)
  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([userId])
  @@index([expiresAt])
}

model McpOAuthAccessToken {
  id             String    @id @default(cuid())
  tokenHash      String    @unique
  refreshHash    String?   @unique
  clientId       String
  userId         String
  organizationId String
  scope          String    @default("mcp")
  expiresAt      DateTime
  revokedAt      DateTime?
  lastUsedAt     DateTime?
  createdAt      DateTime  @default(now())

  client McpOAuthClient @relation(fields: [clientId], references: [clientId], onDelete: Cascade)
  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([userId])
  @@index([expiresAt])
}

// ==================== EVENT STATS (denormalized read model) ====================

model EventStats {
  id                     String   @id @default(cuid())
  eventId                String   @unique
  registrationsByStatus  Json     @default("{}")
  registrationsByPayment Json     @default("{}")
  totalRegistrations     Int      @default(0)
  checkedInCount         Int      @default(0)
  speakersByStatus       Json     @default("{}")
  totalSpeakers          Int      @default(0)
  agreementsSigned       Int      @default(0)
  abstractsByStatus      Json     @default("{}")
  totalSessions          Int      @default(0)
  totalTracks            Int      @default(0)
  computedAt             DateTime @default(now())
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

// ==================== EMAIL LOG (per-send audit) ====================

enum EmailLogEntityType {
  REGISTRATION
  SPEAKER
  CONTACT
  USER
  OTHER
}

enum EmailLogStatus {
  SENT
  FAILED
}

model EmailLog {
  id                String              @id @default(cuid())
  organizationId    String?
  eventId           String?
  entityType        EmailLogEntityType?
  entityId          String?
  to                String
  cc                String?
  bcc               String?
  subject           String
  templateSlug      String?
  provider          String
  providerMessageId String?
  status            EmailLogStatus
  errorMessage      String?             @db.Text
  triggeredByUserId String?
  createdAt         DateTime            @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  event        Event?        @relation(fields: [eventId], references: [id], onDelete: SetNull)
  triggeredBy  User?         @relation(fields: [triggeredByUserId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([organizationId])
  @@index([eventId])
  @@index([to])
  @@index([createdAt])
}
