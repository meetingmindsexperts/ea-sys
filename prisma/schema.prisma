model Registration {
  id                         String                     @id @default(cuid())
  eventId                    String
  ticketTypeId               String?
  pricingTierId              String?
  attendeeId                 String
  userId                     String?
  serialId                   Int?
  status                     RegistrationStatus         @default(PENDING)
  paymentStatus              PaymentStatus              @default(UNPAID)
  /// venue vs online; only a choice on HYBRID events. VIRTUAL ⇒ no
  /// qrCode/badge, uncapped (skips soldCount), no DTCM barcode.
  attendanceMode             AttendanceMode             @default(IN_PERSON)
  qrCode                     String?                    @unique
  dtcmBarcode                String?                    @unique
  badgeType                  String?
  referrer                   String?
  utmSource                  String?
  utmMedium                  String?
  utmCampaign                String?
  checkedInAt                DateTime?
  /// First time this registrant entered our webinar lobby / joined the live
  /// view (set by the presence heartbeat). Durable "Joined" indicator; the
  /// live who's-here-now state lives in WebinarPresence. Same write-once
  /// convention as checkedInAt.
  webinarFirstJoinedAt       DateTime?
  // Badge-print analytics: first-print timestamp + total prints (reprints
  // bump the count). Set by the badge route; powers "badges printed vs
  // registered" and reprint metrics. Per-print history lives in AuditLog
  // (action BADGE_PRINTED).
  badgePrintedAt             DateTime?
  badgePrintCount            Int                        @default(0)
  /// Set when the registrant submits the post-event feedback survey
  /// at `/e/[slug]/survey?token=...`. Used by the reporting view +
  /// audit trail; NOT consumed by the cert eligibility query (the
  /// cert system filters by `Attendee.tags` containing "survey-
  /// completed" which the same submit handler writes). Mirrors the
  /// existing `checkedInAt` / `badgePrintedAt` convention.
  surveyCompletedAt          DateTime?
  /// Phase-2 survey-gated cert auto-issue state. The cert worker sweeps
  /// registrations where `surveyCompletedAt IS NOT NULL AND
  /// certAutoIssueCheckedAt IS NULL AND (nextAttemptAt IS NULL OR <= now)`,
  /// resolves matching auto-issue templates (per tag), enqueues the certs,
  /// then stamps `checkedAt` (terminal). On a transient failure it bumps
  /// `attempts`, records `error`, and sets `nextAttemptAt = now + backoff`
  /// (exponential) so the row defers instead of blocking the queue; after
  /// MAX attempts it gives up terminally (checkedAt set + error kept).
  /// Derivable analytics state:
  ///   checkedAt NULL, attempts 0           → pending (first sweep)
  ///   checkedAt NULL, attempts > 0         → retrying/backing off
  ///   checkedAt set,  error NULL           → resolved OK
  ///   checkedAt set,  error non-NULL       → gave up after retries
  /// Partial index in the migration keeps the candidate scan cheap.
  certAutoIssueCheckedAt     DateTime?
  certAutoIssueAttempts      Int                        @default(0)
  certAutoIssueNextAttemptAt DateTime?
  certAutoIssueError         String?
  /// Which code path created this row — public form vs admin add vs
  /// MCP agent vs CSV import etc. See enum `RegistrationCreatedSource`
  /// for the full list. NULL on historical rows that pre-date the
  /// column; the detail sheet renders "Unknown" for those.
  createdSource              RegistrationCreatedSource?
  notes                      String?                    @db.Text
  // Billing details (for invoices/tax)
  taxNumber                  String?
  billingFirstName           String?
  billingLastName            String?
  billingEmail               String?
  billingPhone               String?
  billingAddress             String?
  billingCity                String?
  billingState               String?
  billingZipCode             String?
  billingCountry             String?
  // Promo code discount
  promoCodeId                String?
  discountAmount             Decimal?                   @db.Decimal(10, 2)
  originalPrice              Decimal?                   @db.Decimal(10, 2)
  /// Running total refunded so far (partial refunds accumulate here). The
  /// registration stays PAID while 0 < refundedAmount < paidTotal and flips
  /// to REFUNDED only when the full paid amount is returned. The Billing UI
  /// shows "Refunded X of Y". Written by the refund route + charge.refunded
  /// webhook reconciliation.
  refundedAmount             Decimal                    @default(0) @db.Decimal(10, 2)
  // Sponsor attribution — set when paymentStatus = INCLUSIVE so reports
  // can group "all Abbott-sponsored attendees." References the entry's
  // id inside Event.settings.sponsors[] JSON (no FK because sponsors
  // are stored as a JSON array on the event, not a Prisma table).
  sponsorId                  String?
  // Third-party billing ("charge to another account") — when set, the
  // invoice is addressed to this BillingAccount (the attendee's hospital,
  // or a pharma/grant covering this specific doctor) instead of the
  // attendee. ORTHOGONAL to paymentStatus: money is still owed and the
  // registration stays UNPAID/PENDING until the payer settles — this only
  // redirects the bill-to party. null = self-pay (unchanged behavior).
  billingAccountId           String?
  // Optional PO / grant / authorization reference printed on the invoice.
  payerReference             String?
  /// Open Stripe Checkout session for this registration, stored at session
  /// create so a CANCEL can EXPIRE it (review H2 sub-item — sessions live
  /// ~24h and a cancelled attendee's still-open payment tab could complete).
  /// Cleared when the session completes or expires.
  stripeCheckoutSessionId    String?
  // Per-registration fallback: when true, an unpaid third-party invoice
  // may be reassigned back to the attendee (finance action); also keeps
  // the attendee's Pay-Now path available as a guarantor.
  attendeeIsGuarantor        Boolean                    @default(false)
  createdAt                  DateTime                   @default(now())
  updatedAt                  DateTime                   @updatedAt

  event                    Event                     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  ticketType               TicketType?               @relation(fields: [ticketTypeId], references: [id])
  pricingTier              PricingTier?              @relation(fields: [pricingTierId], references: [id])
  attendee                 Attendee                  @relation(fields: [attendeeId], references: [id])
  user                     User?                     @relation(fields: [userId], references: [id])
  promoCode                PromoCode?                @relation(fields: [promoCodeId], references: [id])
  billingAccount           BillingAccount?           @relation(fields: [billingAccountId], references: [id], onDelete: Restrict)
  payments                 Payment[]
  accommodation            Accommodation?
  invoices                 Invoice[]
  promoRedemption          PromoCodeRedemption?
  zoomAttendances          ZoomAttendance[]
  webinarPresences         WebinarPresence[]
  issuedCertificates       IssuedCertificate[]
  certificateIssueRunItems CertificateIssueRunItem[]
  // Speakers imported from this registration (0 or 1 in practice; the link
  // is best-effort + nullable, set on the import-registrations path).
  importedSpeakers         Speaker[]                 @relation("SpeakerSourceRegistration")
  surveyResponse           SurveyResponse?
  refundAttempts           RefundAttempt[]

  @@unique([eventId, serialId])
  @@index([sponsorId])
  @@index([billingAccountId])
  @@index([eventId])
  @@index([eventId, status])
  @@index([eventId, ticketTypeId])
  @@index([eventId, attendanceMode])
  @@index([pricingTierId])
  @@index([attendeeId])
  @@index([userId])
  @@index([promoCodeId])
  @@index([status])
  @@index([qrCode])
}

enum RegistrationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  WAITLISTED
  CHECKED_IN
}

enum PaymentStatus {
  UNPAID
  PENDING
  PAID
  COMPLIMENTARY
  REFUNDED
  FAILED
  UNASSIGNED
  INCLUSIVE
}

/// Whether a registrant attends physically at the venue or online.
/// Only surfaced as a choice on HYBRID events. IN_PERSON is the default
/// and the back-compat value for every pre-existing registration.
/// VIRTUAL registrations get NO entry barcode/badge and are uncapped
/// (they don't consume the ticket-type seat count).
enum AttendanceMode {
  IN_PERSON
  VIRTUAL
}

/// Identifies which entry path created a Registration. Used by the
/// detail sheet to show "where did this row come from" so an
/// organizer can tell a self-service public registration from an
/// admin-entered one at a glance. NULL on historical rows that
/// pre-date the column.
enum RegistrationCreatedSource {
  /// Public registration form `/e/[slug]/register/[category]` — the
  /// canonical self-service path. Free + paid both land here.
  PUBLIC_REGISTER
  /// Public abstract-submitter sign-up at `/e/[slug]/abstract/register`
  /// — creates a SUBMITTER user + a Registration in one shot.
  PUBLIC_SUBMITTER
  /// Token-gated completion form at `/e/[slug]/complete-registration`
  /// — used after a CSV import where the admin sends "complete your
  /// registration" emails to imported rows.
  PUBLIC_COMPLETION_FORM
  /// Admin "Add Registration" full-page form or dialog on the
  /// dashboard registrations list. Goes through registration-service.
  ADMIN_DASHBOARD
  /// Bulk CSV import via the dashboard CSV importer.
  CSV_IMPORT
  /// MCP agent tool — `create_registration` or
  /// `create_registrations_bulk` called by an external integration
  /// (n8n, Claude Desktop, claude.ai web).
  MCP_AGENT
  /// Auto-created companion registration backing a Speaker (the "attendee
  /// facet"): comp, uncapped Faculty type, organizer-added. Gives the
  /// speaker badge/barcode/DTCM/check-in/survey via the normal machinery.
  SPEAKER_COMPANION
  /// Catch-all for legacy paths or paths we haven't tagged yet.
  /// Rows landing here are a signal to extend coverage.
  OTHER
}

model Payment {
  id                String        @id @default(cuid())
  registrationId    String
  amount            Decimal       @db.Decimal(10, 2)
  currency          String        @default("USD")
  stripePaymentId   String?       @unique
  stripeCustomerId  String?
  status            PaymentStatus @default(PENDING)
  /// Per-PAYMENT refunded running total (review H6/M4, July 10 2026). The
  /// registration-level `Registration.refundedAmount` mixes Stripe + manual
  /// money; this column tracks how much of THIS payment has been returned, so
  /// refunds allocate across payments (each Stripe slice capped at its own
  /// charge) and `charge.refunded` reconciles Stripe's per-charge cumulative
  /// against the right counter. `status` flips to REFUNDED when this reaches
  /// `amount`.
  refundedAmount    Decimal       @default(0) @db.Decimal(10, 2)
  receiptUrl        String?
  /// Stripe's hosted receipt page URL (charge.receipt_url) — the canonical
  /// "stripe_receipt". `stripeReceiptFile` is our durable local snapshot of that
  /// page (downloaded at settlement), so the receipt survives even if Stripe's
  /// URL ever breaks. Both null for manual/offline payments.
  stripeReceiptUrl  String?
  stripeReceiptFile String?
  // Card / payment instrument details captured from the Stripe PaymentIntent
  // at settlement time. `cardBrand` + `cardLast4` appear on the post-payment
  // Invoice PDF and the registration Billing panel so organizers can
  // reconcile. `paymentMethodType` is Stripe's top-level classification
  // (`card`, `bank_transfer`, `sepa_debit`, etc.). `paidAt` is the authoritative
  // settlement timestamp — `createdAt` records when we inserted the row,
  // which drifts from the actual capture moment under webhook retries.
  cardBrand         String?
  cardLast4         String?
  paymentMethodType String?
  paidAt            DateTime?
  metadata          Json          @default("{}")
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  registration Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  invoice      Invoice?

  @@index([registrationId])
  @@index([stripePaymentId])
}

