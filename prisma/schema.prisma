  @@index([eventId])
  @@index([status])
  @@index([sourceRegistrationId])
}

enum SpeakerStatus {
  INVITED
  CONFIRMED
  DECLINED
  CANCELLED
}

enum SpeakerDocumentKind {
  /// The signed agreement copy the organizer received back (wet signature /
  /// emailed PDF). App-enforced ONE per speaker (per event -- speakers are
  /// event-scoped): a new upload replaces the previous one. Deliberately
  /// SEPARATE from Speaker.agreementAcceptedAt (owner decision July 16,
  /// 2026) -- storing the file does not mark the agreement accepted.
  SIGNED_AGREEMENT
  /// Any other per-speaker file: bio doc, CV, COI form scan, etc.
  OTHER
}

/// Per-speaker uploaded documents (July 16, 2026, owner request): the signed
/// agreement copy for future reference + arbitrary attachments (bio doc ...).
/// Files live under /uploads/speaker-docs/{eventId}/; PDF + DOC/DOCX only,
/// magic-byte validated, 10MB cap (see the documents route).
model SpeakerDocument {
  id           String              @id @default(cuid())
