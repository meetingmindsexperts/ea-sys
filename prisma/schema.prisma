generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==================== CORE ENTITIES ====================

model Organization {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  logo           String?
  primaryColor   String?  @map("primary_color")
  settings       Json     @default("{}")
  // Billing/Company info (for invoice "From" section)
  companyName    String?
  companyAddress String?  @db.Text
  companyCity    String?
  companyState   String?
  companyZipCode String?
  companyCountry String?
  companyPhone   String?
  companyEmail   String?
  taxId          String?
  invoicePrefix  String?  @default("INV")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  users           User[]
  events          Event[]
  contacts        Contact[]
  apiKeys         ApiKey[]
  mediaFiles      MediaFile[]
  invoices        Invoice[]
  scheduledEmails ScheduledEmail[]
  emailLogs       EmailLog[]
  billingAccounts BillingAccount[]
}

model User {
  id              String    @id @default(cuid())
  organizationId  String?
  email           String    @unique
  passwordHash    String
  firstName       String
  lastName        String
  role            UserRole  @default(ORGANIZER)
  specialty       String?
  emailVerified   DateTime?
  termsAcceptedAt DateTime?
  termsAcceptedIp String?
  image           String?
  emailSignature  String?   @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organization              Organization?              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  speakers                  Speaker[]
  registrations             Registration[]
  auditLogs                 AuditLog[]
  accounts                  Account[]
  sessions                  AuthSession[]
  notifications             Notification[]
  mediaFiles                MediaFile[]
  deviceTokens              DeviceToken[]
  scheduledEmails           ScheduledEmail[]
  mcpOAuthAuthCodes         McpOAuthAuthCode[]
  mcpOAuthAccessTokens      McpOAuthAccessToken[]
  abstractReviewerOf        AbstractReviewer[]         @relation("ReviewerOnAbstracts")
  assignedAbstractReviewers AbstractReviewer[]         @relation("AssignedAbstractReviewers")
  abstractSubmissions       AbstractReviewSubmission[] @relation("UserAbstractSubmissions")
  triggeredEmailLogs        EmailLog[]
  attachedBillingAccounts   EventBillingAccount[]
  issuedCertificates        IssuedCertificate[]
  triggeredCertificateRuns  CertificateIssueRun[]

  @@index([organizationId])
  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model AuthSession {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  ORGANIZER
  MEMBER
  REVIEWER
  SUBMITTER
  REGISTRANT
}

enum Title {
  DR
  MR
  MRS
  MS
  PROF
}

enum AttendeeRole {
  ACADEMIA
  ALLIED_HEALTH
  MEDICAL_DEVICES
  PHARMA
  PHYSICIAN
  RESIDENT
  SPEAKER
  STUDENT
  OTHERS
}

model Event {
  id                           String      @id @default(cuid())
  organizationId               String
  name                         String
  slug                         String
  description                  String?     @db.Text
  startDate                    DateTime
  endDate                      DateTime
  timezone                     String      @default("Asia/Dubai")
  venue                        String?
  address                      String?
  city                         String?
  country                      String?
  eventType                    EventType?
  tag                          String?
  specialty                    String?
  code                         String?
  // Dubai (DET/DTCM) compliance: when true, the per-registration DTCM
  // barcode field is surfaced for this event. DTCM barcodes are a Dubai
  // tourism requirement and are NOT applicable to Abu Dhabi / Fujairah /
  // Al Ain / non-UAE events — organizer ticks this only for Dubai events.
  // It does NOT make DTCM the entry barcode (that's always qrCode); it
  // only controls visibility of the separate DTCM field.
  requiresDtcmBarcode          Boolean     @default(false)
  status                       EventStatus @default(DRAFT)
  settings                     Json        @default("{}")
  bannerImage                  String?
  footerHtml                   String?     @db.Text
  emailHeaderImage             String?
  // Responsive logo / sign-off image rendered at the very bottom of
  // every event email body (below the optional emailFooterHtml).
  // Same responsive treatment as emailHeaderImage — width="600"
  // attribute + max-width:600px CSS so Outlook desktop and modern
  // clients both render at the email-body width.
  emailFooterImage             String?
  emailFooterHtml              String?     @db.Text
  emailFromAddress             String?
  emailFromName                String?
  // Addresses CC'd on every event-scoped email — both automated
  // (registration confirmation, speaker invite, abstract status,
  // bulk email, scheduled email) and manual single-sends from the
  // detail sheets. Empty array = no auto-CC.
  emailCcAddresses             String[]    @default([])
  supportEmail                 String?
  registrationTermsHtml        String?     @db.Text
  registrationWelcomeHtml      String?     @db.Text
  abstractWelcomeHtml          String?     @db.Text
  abstractTermsHtml            String?     @db.Text
  abstractConfirmationHtml     String?     @db.Text
  registrationConfirmationHtml String?     @db.Text
  speakerAgreementHtml         String?     @db.Text
  speakerAgreementTemplate     Json?
  /// Per-event post-event evaluation/feedback survey definition. Null
  /// when no survey is configured. Shape: ordered array of
  /// SurveyQuestion (discriminated union: single_select / rating_1_to_5
  /// / text) — see `src/lib/survey/schema.ts` for the Zod-validated
  /// type. Renderer pulls this at request time on both the admin
  /// builder + the public form, so changing it mid-collection is
  /// allowed but care must be taken not to invalidate in-flight
  /// responses (answer linkage is by question.id, not array index).
  surveyConfig                 Json?
  /// Organizer-generated reusable shareable survey link. Null when no
  /// link is active. Shape: `{ token, expiresAt, createdAt,
  /// createdByUserId }` — see `src/lib/survey/share-link.ts` for the
  /// Zod-validated shape. Token is stored PLAINTEXT (like
  /// Abstract.managementToken) so the dashboard can re-display the URL;
  /// a valid registrant email is still required to submit, so this only
  /// gates reaching the form. Lookup is slug-scoped (the public URL
  /// carries the slug), so no global token index is needed.
  surveyShareLink              Json?
  taxRate                      Decimal?    @db.Decimal(5, 2)
  taxLabel                     String?     @default("VAT")
  bankDetails                  String?     @db.Text
  badgeVerticalOffset          Int         @default(0)
  // CME / CPD hours awarded for attending this event. Read by the CME
  // certificate template. Decimal(4,1) allows fractional hours up to
  // 999.9 — accreditors routinely award half-hour increments.
  // Nullable: events that aren't CME-accredited leave this empty and
  // the Issue CME button stays disabled. Per-event accreditor list
  // (DHA / DOH / SCFHS / EACCME / ACCME / OTHER — multiple allowed)
  // lives in `settings.cme.accreditations[]` JSON, not a separate
  // column, because: at most 2-3 accreditations per event in practice,
  // we never query by reference, and it matches the existing
  // settings-blob pattern (settings.zoom, settings.sponsors,
  // settings.webinar). Design-approval flag for cert templates lives
  // in `settings.cme.designApprovedBy` + `designApprovedAt`.
  cmeHours                     Decimal?    @db.Decimal(4, 1)
  externalId                   String?
  externalSource               String?
  createdAt                    DateTime    @default(now())
  updatedAt                    DateTime    @updatedAt

  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ticketTypes    TicketType[]
  registrations  Registration[]
  speakers       Speaker[]
  eventSessions  EventSession[]
  tracks         Track[]
  hotels         Hotel[]
  accommodations Accommodation[]
  abstracts      Abstract[]
  abstractThemes AbstractTheme[]
  reviewCriteria ReviewCriterion[]
  auditLogs      AuditLog[]

  importLogs                ImportLog[]
  emailTemplates            EmailTemplate[]
  notifications             Notification[]
  mediaFiles                MediaFile[]
  invoices                  Invoice[]
  invoiceCounters           InvoiceCounter[]
  registrationSerialCounter RegistrationSerialCounter?
  billingAccounts           EventBillingAccount[]
  zoomMeetings              ZoomMeeting[]
  zoomAttendances           ZoomAttendance[]
  promoCodes                PromoCode[]
  scheduledEmails           ScheduledEmail[]
  eventStats                EventStats?
  emailLogs                 EmailLog[]
  issuedCertificates        IssuedCertificate[]
  certificateSerialCounters CertificateSerialCounter[]
  certificateIssueRuns      CertificateIssueRun[]
  certificateTemplates      CertificateTemplate[]
  surveyResponses           SurveyResponse[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([status])
  @@index([startDate])
  @@index([externalSource, externalId])
}

// ==================== CERTIFICATES ====================

// Collapsed from 4 to 2 values on 2026-06-02. Designers typically hand
// the organizer two physical cert PDFs — "Certificate of Attendance"
// and "Certificate of Appreciation" — and the organizer modifies the
// per-recipient text via {{tokens}} on text boxes overlaid on each.
// PRESENTER + POSTER + CME were collapsed into APPRECIATION; CME
// metadata (hours + accrediting bodies) stays on the event itself and
// is rendered into either cert type via tokens (`{{cmeHours}}`,
// `{{accreditationBody}}`, `{{accreditationReference}}`).
enum CertificateType {
  ATTENDANCE
  APPRECIATION
}

/// Per-event-per-type atomic serial counter — mirrors RegistrationSerialCounter
/// (added 2026-05-18). One row per `(eventId, type)`. PK is composite so we
/// can upsert+increment in a single statement under concurrent issues
/// without P2002 collisions on `IssuedCertificate.serial`'s unique index.
///
/// Serials are CATEGORY-scoped, not template-scoped — a single attendance
/// numbering sequence covers Standard + VIP + any other Attendance variant
/// the organizer creates. The category is what reads as the cert's identity
/// in serial-number registries.
model CertificateSerialCounter {
  eventId    String
  type       CertificateType
  lastSerial Int             @default(0)

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@id([eventId, type])
}

/// User-defined certificate template (2026-06-02 — N templates per event-per-
/// category, replacing the previous 2-slot JSON on Event.settings). Each
/// row carries its own background PDF + positioned text boxes; the operator
/// can have multiple Attendance designs (e.g. "Standard", "VIP", "Sponsor
/// Guest") and multiple Appreciation designs (e.g. "Speaker", "Moderator",
/// "Chairman") per event.
///
/// `category` derives the eligibility query (Attendance → checked-in
/// registrants; Appreciation → speakers + poster authors). One cert per
/// recipient per category — the uniqueness on IssuedCertificate prevents
/// double-issue even when multiple templates of the same category exist.
///
/// Template DELETE is blocked at the application layer when any
/// IssuedCertificate still references it (FK is SetNull so the row can be
/// orphaned in extremis, but the API rejects). This preserves issued-cert
/// audit trail integrity.
model CertificateTemplate {
  id               String          @id @default(cuid())
  eventId          String
  name             String // organizer-defined, e.g. "VIP Attendance"
  category         CertificateType // ATTENDANCE | APPRECIATION
  backgroundPdfUrl String?
  // CertificateTextBox[] — same shape as src/lib/certificates/types.ts
  textBoxes        Json            @default("[]")
  sortOrder        Int             @default(0)
  // Per-template default cover email (cert PDF is always attached). Both
  // nullable — when null the Issue dialog pre-fills the system default.
  // Tokens supported in body: recipientName, eventName, eventDateRange,
  // venueLine, organizationName, certificateType, certificateSerial,
  // plus abstractTitle on APPRECIATION templates.
  emailSubject     String?
  emailBody        String?         @db.Text
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  event              Event                 @relation(fields: [eventId], references: [id], onDelete: Cascade)
  issuedCertificates IssuedCertificate[]
  issueRuns          CertificateIssueRun[]

  @@index([eventId, category, sortOrder])
}

/// Audit record of a certificate that was actually issued + emailed. One row
/// per (event, type, recipient) — the dual @@unique constraints prevent
/// accidental double-issue from concurrent operator clicks or MCP retries.
///
/// `recipientSnapshot` and `cmeHoursSnapshot` lock in the values at issue
/// time so a reprint months later matches the original PDF byte-for-byte
/// even if the underlying Attendee/Speaker/Event record drifts. Mirrors
/// the immutability strategy `Speaker.agreementTextSnapshot` uses for
/// legal-text fixity.
model IssuedCertificate {
  id                    String          @id @default(cuid())
  eventId               String
  registrationId        String?
  speakerId             String?
  type                  CertificateType
  /// Specific template that rendered this cert. Nullable so legacy rows
  /// (pre-2026-06-02 multi-template flip) survive; new issues always set it.
  /// SetNull on template delete — audit trail preserved even if the
  /// organizer later deletes the template that produced this cert.
  certificateTemplateId String?
  serial                String          @unique
  issuedAt              DateTime        @default(now())
  issuedByUserId        String
  lastReprintedAt       DateTime?
  reprintCount          Int             @default(0)
  /// Tracks individual-recipient resends from the registration/speaker
  /// detail sheets (distinct from reprint which re-renders the PDF —
  /// resend reuses the existing pdfUrl and just re-fires the delivery
  /// email). Each resend bumps both fields atomically. resendCount=0
  /// means the cert was sent once via the original CertificateIssueRun
  /// and never resent.
  lastResentAt          DateTime?
  resendCount           Int             @default(0)
  revokedAt             DateTime?
  revocationReason      String?

  // Frozen at issue time. Schema:
  //   { title, firstName, lastName, fullName (formatted),
  //     organization?, jobTitle?, city?, country? }
  recipientSnapshot Json
  cmeHoursSnapshot  Decimal? @db.Decimal(4, 1)

  // URL to the rendered PDF — populated by the issue cron during the
  // RENDERING phase. Path convention: /uploads/certificates/{eventId}/{certId}.pdf
  // (local) or certificates/{eventId}/{certId}.pdf (Supabase storage).
  // Reused for re-download + email attachment so we don't re-render. NULL
  // until the render phase completes for this cert.
  pdfUrl String?

  event               Event                    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  registration        Registration?            @relation(fields: [registrationId], references: [id], onDelete: SetNull)
  speaker             Speaker?                 @relation(fields: [speakerId], references: [id], onDelete: SetNull)
  issuedBy            User                     @relation(fields: [issuedByUserId], references: [id])
  certificateTemplate CertificateTemplate?     @relation(fields: [certificateTemplateId], references: [id], onDelete: SetNull)
  issueRunItem        CertificateIssueRunItem?

  @@unique([eventId, type, registrationId])
  @@unique([eventId, type, speakerId])
  @@index([eventId, type])
  @@index([certificateTemplateId])
  @@index([serial])
}

/// Bulk certificate-issuing run. One row per "issue all certificates of
/// type X" operator action. Drives a two-phase pipeline:
///   PENDING → RENDERING → AWAITING_REVIEW → SENDING → COMPLETED
/// The AWAITING_REVIEW gate is the operator preview — they can verify
/// the rendered PDFs look right before emails go out.
///
/// The cron worker /api/cron/certificate-issues picks up runs in
/// non-terminal states and drains them in batches of 50 per tick. App-
/// level guard in POST /issue ensures only one non-terminal run per
/// (event, type) so concurrent operator clicks don't double-issue.
model CertificateIssueRun {
  id                    String             @id @default(cuid())
  eventId               String
  type                  CertificateType
  /// Which template fired this run. Nullable for legacy rows (pre-flip);
  /// new runs always set it. SetNull on template delete — the run row
  /// survives as audit even if the template is later removed.
  certificateTemplateId String?
  status                CertIssueRunStatus @default(PENDING)
  totalCount            Int
  renderedCount         Int                @default(0)
  emailedCount          Int                @default(0)
  failedCount           Int                @default(0)
  triggeredByUserId     String
  triggeredAt           DateTime           @default(now())
  rendererStartedAt     DateTime?
  rendererFinishedAt    DateTime?
  emailerStartedAt      DateTime?
  emailerFinishedAt     DateTime?
  // Heartbeat — cron worker updates on every tick. Stall detector
  // reclaims any IN_PROGRESS run (RENDERING / SENDING) whose lastTickAt
  // is older than 10 minutes back to PENDING / AWAITING_REVIEW so a
  // crashed mid-tick run doesn't get stuck forever.
  lastTickAt            DateTime?
  // [{ recipientName, phase, code, message }] — capped at last 100 in code.
  errors                Json?
  // Optional: when SENDING completes, snapshot the sender's cc list so
  // re-runs can replay. Not required for v1.
  notes                 String?
  // Snapshot of the email content the operator confirmed at Issue time
  // (copied from the template default into the dialog, optionally
  // tweaked, then frozen onto the run). The send phase reads from here
  // — NOT from the template — so a template-default-change mid-run
  // doesn't retroactively alter the in-flight emails.
  emailSubject          String?
  emailBody             String?            @db.Text

  event               Event                     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  triggeredBy         User                      @relation(fields: [triggeredByUserId], references: [id])
  certificateTemplate CertificateTemplate?      @relation(fields: [certificateTemplateId], references: [id], onDelete: SetNull)
  items               CertificateIssueRunItem[]

  @@index([eventId, type, status])
  @@index([certificateTemplateId])
  @@index([status, lastTickAt])
}

enum CertIssueRunStatus {
  PENDING
  RENDERING
  AWAITING_REVIEW
  SENDING
  COMPLETED
  FAILED
  CANCELLED
}

/// One row per (run, recipient) — the unit of work the cron drains.
/// Disambiguated by registrationId XOR speakerId. Carries per-item
/// progress (renderedAt, issuedCertificateId, emailedAt, error*) so
/// the cron can resume mid-batch + re-issue-failed-only is trivial.
model CertificateIssueRunItem {
  id                  String    @id @default(cuid())
  runId               String
  registrationId      String?
  speakerId           String?
  // Snapshot at run-creation time — used to display the recipient list
  // in the UI without joining + handles the case where the underlying
  // Registration/Speaker is later cancelled (we still want to show
  // who was on the run).
  recipientName       String
  recipientEmail      String?
  renderedAt          DateTime?
  issuedCertificateId String?   @unique
  emailedAt           DateTime?
  errorPhase          String? // "render" | "email"
  errorMessage        String?

  run               CertificateIssueRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  registration      Registration?       @relation(fields: [registrationId], references: [id], onDelete: SetNull)
  speaker           Speaker?            @relation(fields: [speakerId], references: [id], onDelete: SetNull)
  issuedCertificate IssuedCertificate?  @relation(fields: [issuedCertificateId], references: [id])

  @@unique([runId, registrationId])
  @@unique([runId, speakerId])
  @@index([runId, renderedAt])
  @@index([runId, emailedAt])
}

enum EventStatus {
  DRAFT
  PUBLISHED
  LIVE
  COMPLETED
  CANCELLED
}

enum EventType {
  CONFERENCE
  WEBINAR
  HYBRID
}

// ==================== SURVEY ====================
// Per-event post-event feedback survey. Question definitions live as
// JSON on `Event.surveyConfig` (see prisma/schema.prisma:~205 and
// src/lib/survey/schema.ts for the Zod-validated type). Each
// registration can submit AT MOST one response — the unique
// (eventId, registrationId) constraint is the dedup gate. The submit
// handler also writes the "survey-completed" tag onto Attendee.tags,
// which the cert Issue UI's tag picker filters by (CME certs gate on
// it; ATTENDANCE certs typically don't). See
// docs/SURVEYS.md (when added) for the full operator workflow.

model SurveyResponse {
  id             String   @id @default(cuid())
  eventId        String
  /// One response per registration — enforced by `@unique`. The 1:1
  /// relation requires this on the FK side; conceptually it's also
  /// the dedup gate (a second POST returns 200 no-op via P2002).
  registrationId String   @unique
  submittedAt    DateTime @default(now())
  /// Hashed (NEXTAUTH_SECRET-peppered) source IP, for abuse triage
  /// without leaking the raw address. Optional — empty for anonymous
  /// flows we don't currently support.
  ipHash         String?
  /// Frozen answers keyed by question.id from Event.surveyConfig at
  /// submit time. Values are typed by the question type:
  ///   single_select → string (one of the configured options)
  ///   rating_1_to_5 → number 1..5
  ///   text          → string
  /// Skipped (optional) questions are absent from the map, NOT null.
  answers        Json

  event        Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  registration Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@index([eventId, submittedAt])
}

// ==================== REGISTRATION & TICKETING ====================

model TicketType {
  id          String   @id @default(cuid())
  eventId     String
  name        String
  description String?  @db.Text
  isDefault   Boolean  @default(false)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Deprecated: kept for migration backward compat, will be removed
  category         String    @default("Standard")
  price            Decimal   @default(0) @db.Decimal(10, 2)
  currency         String    @default("USD")
  quantity         Int       @default(999999)
  soldCount        Int       @default(0)
  maxPerOrder      Int       @default(10)
  salesStart       DateTime?
  salesEnd         DateTime?
  requiresApproval Boolean   @default(false)

  event          Event                 @relation(fields: [eventId], references: [id], onDelete: Cascade)
  pricingTiers   PricingTier[]
  registrations  Registration[]
  promoCodeLinks PromoCodeTicketType[]

  @@index([eventId])
  @@index([isActive])
}

model PricingTier {
  id               String    @id @default(cuid())
  ticketTypeId     String
  name             String
  price            Decimal   @default(0) @db.Decimal(10, 2)
  currency         String    @default("USD")
  quantity         Int       @default(999999)
  soldCount        Int       @default(0)
  maxPerOrder      Int       @default(10)
  salesStart       DateTime?
  salesEnd         DateTime?
  isActive         Boolean   @default(true)
  requiresApproval Boolean   @default(false)
  sortOrder        Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  ticketType    TicketType     @relation(fields: [ticketTypeId], references: [id], onDelete: Cascade)
  registrations Registration[]

  @@unique([ticketTypeId, name])
  @@index([ticketTypeId])
  @@index([isActive])
}

model Attendee {
  id               String        @id @default(cuid())
  title            Title?
  role             AttendeeRole?
  email            String
  additionalEmail  String?
  firstName        String
  lastName         String
  organization     String?
  jobTitle         String?
  phone            String?
  photo            String?
  city             String?
  state            String?
  zipCode          String?
  country          String?
  bio              String?       @db.Text
  specialty        String?
  customSpecialty  String?
  registrationType String?
  tags             String[]      @default([])
  dietaryReqs      String?
  associationName  String?
  memberId         String?
  studentId        String?
  studentIdExpiry  DateTime?
  customFields     Json          @default("{}")
  externalId       String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  registrations Registration[]

  @@index([email])
}

model Registration {
  id                  String             @id @default(cuid())
  eventId             String
  ticketTypeId        String?
  pricingTierId       String?
  attendeeId          String
  userId              String?
  serialId            Int?
  status              RegistrationStatus @default(PENDING)
  paymentStatus       PaymentStatus      @default(UNPAID)
  qrCode              String?            @unique
  dtcmBarcode         String?            @unique
  badgeType           String?
  referrer            String?
  utmSource           String?
  utmMedium           String?
  utmCampaign         String?
  checkedInAt         DateTime?
  // Badge-print analytics: first-print timestamp + total prints (reprints
  // bump the count). Set by the badge route; powers "badges printed vs
  // registered" and reprint metrics. Per-print history lives in AuditLog
  // (action BADGE_PRINTED).
  badgePrintedAt      DateTime?
  badgePrintCount     Int                @default(0)
  /// Set when the registrant submits the post-event feedback survey
  /// at `/e/[slug]/survey?token=...`. Used by the reporting view +
  /// audit trail; NOT consumed by the cert eligibility query (the
  /// cert system filters by `Attendee.tags` containing "survey-
  /// completed" which the same submit handler writes). Mirrors the
  /// existing `checkedInAt` / `badgePrintedAt` convention.
  surveyCompletedAt   DateTime?
  /// Which code path created this row — public form vs admin add vs
  /// MCP agent vs CSV import etc. See enum `RegistrationCreatedSource`
  /// for the full list. NULL on historical rows that pre-date the
  /// column; the detail sheet renders "Unknown" for those.
  createdSource       RegistrationCreatedSource?
  notes               String?            @db.Text
  // Billing details (for invoices/tax)
  taxNumber           String?
  billingFirstName    String?
  billingLastName     String?
  billingEmail        String?
  billingPhone        String?
  billingAddress      String?
  billingCity         String?
  billingState        String?
  billingZipCode      String?
  billingCountry      String?
  // Promo code discount
  promoCodeId         String?
  discountAmount      Decimal?           @db.Decimal(10, 2)
  originalPrice       Decimal?           @db.Decimal(10, 2)
  // Sponsor attribution — set when paymentStatus = INCLUSIVE so reports
  // can group "all Abbott-sponsored attendees." References the entry's
  // id inside Event.settings.sponsors[] JSON (no FK because sponsors
  // are stored as a JSON array on the event, not a Prisma table).
  sponsorId           String?
  // Third-party billing ("charge to another account") — when set, the
  // invoice is addressed to this BillingAccount (the attendee's hospital,
  // or a pharma/grant covering this specific doctor) instead of the
  // attendee. ORTHOGONAL to paymentStatus: money is still owed and the
  // registration stays UNPAID/PENDING until the payer settles — this only
  // redirects the bill-to party. null = self-pay (unchanged behavior).
  billingAccountId    String?
  // Optional PO / grant / authorization reference printed on the invoice.
  payerReference      String?
  // Per-registration fallback: when true, an unpaid third-party invoice
  // may be reassigned back to the attendee (finance action); also keeps
  // the attendee's Pay-Now path available as a guarantor.
  attendeeIsGuarantor Boolean            @default(false)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  event                    Event                     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  ticketType               TicketType?               @relation(fields: [ticketTypeId], references: [id])
  pricingTier              PricingTier?              @relation(fields: [pricingTierId], references: [id])
  attendee                 Attendee                  @relation(fields: [attendeeId], references: [id])
  user                     User?                     @relation(fields: [userId], references: [id])
  promoCode                PromoCode?                @relation(fields: [promoCodeId], references: [id])
  billingAccount           BillingAccount?           @relation(fields: [billingAccountId], references: [id], onDelete: Restrict)
  payments                 Payment[]
  accommodation            Accommodation?
  invoices                 Invoice[]
  promoRedemption          PromoCodeRedemption?
  zoomAttendances          ZoomAttendance[]
  issuedCertificates       IssuedCertificate[]
  certificateIssueRunItems CertificateIssueRunItem[]
  surveyResponse           SurveyResponse?

  @@unique([eventId, serialId])
  @@index([sponsorId])
  @@index([billingAccountId])
  @@index([eventId])
  @@index([eventId, status])
  @@index([eventId, ticketTypeId])
  @@index([pricingTierId])
  @@index([attendeeId])
  @@index([userId])
  @@index([promoCodeId])
  @@index([status])
  @@index([qrCode])
}

enum RegistrationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  WAITLISTED
  CHECKED_IN
}

enum PaymentStatus {
  UNPAID
  PENDING
  PAID
  COMPLIMENTARY
  REFUNDED
  FAILED
  UNASSIGNED
  INCLUSIVE
}

/// Identifies which entry path created a Registration. Used by the
/// detail sheet to show "where did this row come from" so an
/// organizer can tell a self-service public registration from an
/// admin-entered one at a glance. NULL on historical rows that
/// pre-date the column.
enum RegistrationCreatedSource {
  /// Public registration form `/e/[slug]/register/[category]` — the
  /// canonical self-service path. Free + paid both land here.
  PUBLIC_REGISTER
  /// Public abstract-submitter sign-up at `/e/[slug]/abstract/register`
  /// — creates a SUBMITTER user + a Registration in one shot.
  PUBLIC_SUBMITTER
  /// Token-gated completion form at `/e/[slug]/complete-registration`
  /// — used after a CSV import where the admin sends "complete your
  /// registration" emails to imported rows.
  PUBLIC_COMPLETION_FORM
  /// Admin "Add Registration" full-page form or dialog on the
  /// dashboard registrations list. Goes through registration-service.
  ADMIN_DASHBOARD
  /// Bulk CSV import via the dashboard CSV importer.
  CSV_IMPORT
  /// MCP agent tool — `create_registration` or
  /// `create_registrations_bulk` called by an external integration
  /// (n8n, Claude Desktop, claude.ai web).
  MCP_AGENT
  /// Catch-all for legacy paths or paths we haven't tagged yet.
  /// Rows landing here are a signal to extend coverage.
  OTHER
}

model Payment {
  id                String        @id @default(cuid())
  registrationId    String
  amount            Decimal       @db.Decimal(10, 2)
  currency          String        @default("USD")
  stripePaymentId   String?       @unique
  stripeCustomerId  String?
  status            PaymentStatus @default(PENDING)
  receiptUrl        String?
  // Card / payment instrument details captured from the Stripe PaymentIntent
  // at settlement time. `cardBrand` + `cardLast4` appear on the post-payment
  // Invoice PDF and the registration Billing panel so organizers can
  // reconcile. `paymentMethodType` is Stripe's top-level classification
  // (`card`, `bank_transfer`, `sepa_debit`, etc.). `paidAt` is the authoritative
  // settlement timestamp — `createdAt` records when we inserted the row,
  // which drifts from the actual capture moment under webhook retries.
  cardBrand         String?
  cardLast4         String?
  paymentMethodType String?
  paidAt            DateTime?
  metadata          Json          @default("{}")
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  registration Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  invoice      Invoice?

  @@index([registrationId])
  @@index([stripePaymentId])
}

