enum AccommodationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  CHECKED_IN
  CHECKED_OUT
}

// ==================== CONTACT STORE ====================

model Contact {
  id               String        @id @default(cuid())
  organizationId   String
  org              Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  title            Title?
  role             AttendeeRole?
  email            String
  additionalEmail  String?
  firstName        String
  lastName         String
  organization     String?
  jobTitle         String?
  bio              String?       @db.Text
  specialty        String?
  customSpecialty  String?
  registrationType String?
  phone            String?
  photo            String?
  city             String?
  state            String?
  zipCode          String?
  country          String?
  associationName  String?
  memberId         String?
  studentId        String?
  studentIdExpiry  DateTime?
  tags             String[]      @default([])
  eventIds         String[]      @default([])
  notes            String?       @db.Text
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  /// CRM module: business contacts (pharma reps, exhibitor sales, procurement)
  /// live in their own `CrmContact` table, NOT here. This table is the EVENT
  /// contact store — HCPs: doctors, nurses, allied health — and every row in it
  /// is mirrored to the external `contacts_centralv1` marketing table by
  /// contacts-central-sync (which has NO where-clause). Putting a pharma rep in
  /// here would market to them as if they were a doctor.
  ///
  /// The rare person who is BOTH (a rep who also attends) is POINTED AT from
  /// `CrmContact.contactId` — linked, never duplicated. Same shape as
  /// `Speaker.sourceRegistrationId`.
  crmContacts CrmContact[]

  @@unique([organizationId, email])
  @@index([organizationId])
}

// ==================== MEDIA ====================

model MediaFile {
  id             String   @id @default(cuid())
  organizationId String
  eventId        String?
  uploadedById   String
  filename       String
  url            String
  mimeType       String
  size           Int
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  event        Event?       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  uploadedBy   User         @relation(fields: [uploadedById], references: [id])

  @@index([organizationId])
  @@index([eventId])
}

// ==================== AUDIT & LOGGING ====================

model AuditLog {
  id         String   @id @default(cuid())
  eventId    String?
  userId     String?
  action     String
  entityType String
  entityId   String
  changes    Json     @default("{}")
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  event Event? @relation(fields: [eventId], references: [id], onDelete: SetNull)
  user  User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([eventId])
  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  // Analytics time-series: "all CHECK_IN / BADGE_PRINTED actions for event E,
  // bucketed by time" — without this the histogram queries full-scan.
  @@index([eventId, action, createdAt])
}

model SystemLog {
  id        String   @id @default(cuid())
  level     String // error, warn, info, debug
  module    String // api, auth, database, events, middleware
  message   String   @db.Text
  timestamp DateTime @default(now())

  @@index([timestamp])
  @@index([level])
  @@index([module])
}

// ==================== IMPORT LOGS ====================

model ImportLog {
  id             String   @id @default(cuid())
  eventId        String
  userId         String
  source         String // "eventsair" | "csv"
  entityType     String // "contacts" | "registrations" | "speakers" | "sessions"
  totalProcessed Int
  totalCreated   Int
  totalSkipped   Int
  totalErrors    Int
  skippedDetails Json     @default("[]") // [{ email, reason }]
  errors         Json     @default("[]") // string[]
  createdAt      DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([createdAt])
}

// ==================== EMAIL TEMPLATES ====================

model EmailTemplate {
  id          String   @id @default(cuid())
  eventId     String
  slug        String // e.g. "registration-confirmation", "speaker-invitation"
  name        String // Human-readable: "Registration Confirmation"
  subject     String // Subject line with {{variables}}
  htmlContent String   @db.Text // HTML body with {{variables}}
  textContent String?  @db.Text // Plain text fallback
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, slug])
  @@index([eventId])
}

// ==================== NOTIFICATIONS ====================

model Notification {
  id        String   @id @default(cuid())
  userId    String
  eventId   String?
  type      String // REGISTRATION, PAYMENT, ABSTRACT, REVIEW, CHECK_IN
  title     String
  message   String
  link      String? // URL to navigate to when clicked
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event? @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

// ==================== MOBILE PUSH NOTIFICATIONS ====================

model DeviceToken {
  id        String   @id @default(cuid())
  userId    String
  platform  String // "ios" or "android"
  pushToken String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, pushToken])
  @@index([userId])
}

// ==================== API KEYS ====================

model ApiKey {
  id             String              @id @default(cuid())
  organizationId String
  name           String
  keyHash        String              @unique
  prefix         String
  createdAt      DateTime            @default(now())
  lastUsedAt     DateTime?
  expiresAt      DateTime?
  isActive       Boolean             @default(true)
  rateLimitTier  ApiKeyRateLimitTier @default(NORMAL)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([isActive])
}

enum ApiKeyRateLimitTier {
  NORMAL
  INTERNAL
}

// ==================== INVOICES & RECEIPTS ====================

model Invoice {
  id             String  @id @default(cuid())
  organizationId String
  eventId        String
  registrationId String
  paymentId      String? @unique

  type           InvoiceType
  invoiceNumber  String      @unique
  sequenceNumber Int

  status InvoiceStatus @default(DRAFT)

  issueDate DateTime  @default(now())
  dueDate   DateTime?
  paidDate  DateTime?

  // Financial snapshot (frozen at creation time)
  subtotal       Decimal  @db.Decimal(10, 2)
  discountCode   String?
  discountAmount Decimal  @default(0) @db.Decimal(10, 2)
  taxRate        Decimal? @db.Decimal(5, 2)
  taxLabel       String?
  taxAmount      Decimal  @default(0) @db.Decimal(10, 2)
  total          Decimal  @db.Decimal(10, 2)
  currency       String   @default("USD")

  paymentMethod    String?
  paymentReference String?
  parentInvoiceId  String?

  notes  String?   @db.Text
  sentAt DateTime?
  sentTo String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  event         Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  registration  Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  payment       Payment?     @relation(fields: [paymentId], references: [id])
  parentInvoice Invoice?     @relation("CreditNotes", fields: [parentInvoiceId], references: [id])
  creditNotes   Invoice[]    @relation("CreditNotes")

  @@unique([eventId, sequenceNumber, type])
  @@index([eventId])
  @@index([registrationId])
  @@index([status])
  @@index([issueDate])
}

model InvoiceCounter {
  id           String      @id @default(cuid())
  eventId      String
  type         InvoiceType
  lastSequence Int         @default(0)

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, type])
}

// One row per event holding the last-assigned registration serialId.
// Mutated via an atomic upsert+increment (see src/lib/registration-serial.ts)
// so concurrent registrations can't collide on @@unique([eventId, serialId]).
model RegistrationSerialCounter {
  eventId    String @id
  lastSerial Int    @default(0)

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

// Reusable org-scoped payer for "charge to another account" — a doctor's
// hospital, or a pharma/grant covering specific HCPs. Distinct from
// Event.settings.sponsors[] (bulk pre-paid INCLUSIVE deals) and from the
// Registration.billing* block (same payer, different address). Soft-delete
// via isActive; the Registration FK is Restrict so a payer with linked
// registrations can't be hard-deleted out from under them.
model BillingAccount {
  id             String             @id @default(cuid())
  organizationId String
  name           String
  type           BillingAccountType @default(INSTITUTION)
  email          String?
  phone          String?
  contactName    String?
  address        String?
  city           String?
  state          String?
  zipCode        String?
  country        String?
  taxNumber      String?
  notes          String?            @db.Text
  isActive       Boolean            @default(true)
  // True until finance reviews a payer created from the public
  // registration flow (prevents "Cleveland Clinic" vs "cleveland clinic
  // inc" duplicates from going straight into the canonical list).
  needsReview    Boolean            @default(false)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  organization  Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  registrations Registration[]
  events        EventBillingAccount[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

enum BillingAccountType {
  INSTITUTION
  COMPANY
  OTHER
}

// Per-event availability of a BillingAccount. Junction (a.k.a. associative)
// table giving a many-to-many between Event and BillingAccount with SHARED
// IDENTITY — one logical "Cleveland Clinic" payer can be attached to many
// events, but the BillingAccount row is never duplicated. The picker on
// each event filters to the payers attached via this table, so events
// don't see an overflow of every payer in the org.
model EventBillingAccount {
  id               String   @id @default(cuid())
  eventId          String
  billingAccountId String
  addedAt          DateTime @default(now())
  addedByUserId    String?

  event          Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  billingAccount BillingAccount @relation(fields: [billingAccountId], references: [id], onDelete: Cascade)
  addedBy        User?          @relation(fields: [addedByUserId], references: [id], onDelete: SetNull)

  @@unique([eventId, billingAccountId])
  @@index([eventId])
  @@index([billingAccountId])
}

enum InvoiceType {
  INVOICE
  RECEIPT
  CREDIT_NOTE
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
  REFUNDED
}

// ==================== ZOOM INTEGRATION ====================

model ZoomMeeting {
  id                   String            @id @default(cuid())
  sessionId            String            @unique
  eventId              String
  zoomMeetingId        String
  meetingType          ZoomMeetingType
  joinUrl              String
  startUrl             String?           @db.Text
  passcode             String?
  duration             Int?
  status               ZoomMeetingStatus @default(CREATED)
  isRecurring          Boolean           @default(false)
  recurrenceType       Int?
  occurrences          Json?
  zoomResponse         Json?
  // Live streaming (RTMP → MediaMTX → HLS)
  liveStreamEnabled    Boolean           @default(false)
  streamKey            String? // unique key for RTMP path
  streamStatus         StreamStatus      @default(IDLE)
  // Cloud recording (fetched by /api/cron/webinar-recordings post-event)
  recordingUrl         String?           @db.Text
  recordingPassword    String?
  recordingDownloadUrl String?           @db.Text
  recordingDuration    Int? // seconds
  recordingFetchedAt   DateTime?
  recordingStatus      RecordingStatus   @default(NOT_REQUESTED)
  // Attendance tracking (fetched by /api/cron/webinar-attendance post-event)
  lastAttendanceSyncAt DateTime?
  // Engagement (polls + Q&A, fetched alongside attendance post-event)
  lastEngagementSyncAt DateTime?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  session     EventSession      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  event       Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  attendances ZoomAttendance[]
  polls       WebinarPoll[]
  questions   WebinarQuestion[]

  @@index([eventId])
  @@index([zoomMeetingId])
  @@index([recordingStatus])
  @@index([lastAttendanceSyncAt])
}

// ── Webinar polls (fetched from Zoom's /report/webinars/{id}/polls) ──
model WebinarPoll {
  id            String   @id @default(cuid())
  zoomMeetingId String
  zoomPollId    String? // Zoom's poll id (nullable for imported/legacy rows)
  title         String
  questions     Json     @default("[]") // [{ name, question_type, answer_details?: [] }]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  zoomMeeting ZoomMeeting           @relation(fields: [zoomMeetingId], references: [id], onDelete: Cascade)
  responses   WebinarPollResponse[]

  @@unique([zoomMeetingId, zoomPollId])
  @@index([zoomMeetingId])
}

// One row per participant per poll submission
model WebinarPollResponse {
  id               String   @id @default(cuid())
  pollId           String
  participantName  String
  participantEmail String?
  answers          Json     @default("{}") // { questionName: answer[] }
  submittedAt      DateTime

  poll WebinarPoll @relation(fields: [pollId], references: [id], onDelete: Cascade)

  @@index([pollId])
}

// ── Webinar Q&A (fetched from Zoom's /report/webinars/{id}/qa) ──
model WebinarQuestion {
  id             String   @id @default(cuid())
  zoomMeetingId  String
  askerName      String
  askerEmail     String?
  question       String   @db.Text
  answer         String?  @db.Text
  answeredByName String?
  askedAt        DateTime

  zoomMeeting ZoomMeeting @relation(fields: [zoomMeetingId], references: [id], onDelete: Cascade)

  @@unique([zoomMeetingId, askerName, askedAt])
  @@index([zoomMeetingId])
}

// ── Per-attendee join/leave records pulled from Zoom's participant report ──
model ZoomAttendance {
  id                 String    @id @default(cuid())
  zoomMeetingId      String
  eventId            String
  sessionId          String
  registrationId     String? // best-effort match by email
  zoomParticipantId  String? // Zoom's per-session participant id
  name               String
  email              String?
  joinTime           DateTime
  leaveTime          DateTime?
  durationSeconds    Int // sum from Zoom report
  attentivenessScore Int? // Zoom returns this for some webinars
  createdAt          DateTime  @default(now())

  zoomMeeting  ZoomMeeting   @relation(fields: [zoomMeetingId], references: [id], onDelete: Cascade)
  event        Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  session      EventSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  registration Registration? @relation(fields: [registrationId], references: [id], onDelete: SetNull)

  // A single Zoom participant id can join+leave multiple times; the report
  // returns one row per join/leave segment, so the unique key includes joinTime
  // to keep them distinct without losing the rejoin history.
  @@unique([zoomMeetingId, zoomParticipantId, joinTime])
  @@index([zoomMeetingId])
  @@index([eventId, sessionId])
  @@index([email])
  @@index([registrationId])
}

// Real-time presence of registered attendees on our webinar lobby / live page.
// This tracks OUR page being open (heartbeat), NOT actual Zoom viewing — the
// authoritative post-event attendance lives in ZoomAttendance. One row per
// (session, registration); the heartbeat upserts lastSeenAt, and "who's here
// now" = rows with a recent lastSeenAt. Kept off the hot Registration row to
// avoid lock/vacuum churn on a finance-bearing table.
model WebinarPresence {
  id             String   @id @default(cuid())
  eventId        String
  sessionId      String
  registrationId String
  firstJoinedAt  DateTime @default(now())
  lastSeenAt     DateTime @default(now())
  joinCount      Int      @default(1)
  phase          String   @default("lobby") // "lobby" | "joined"
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  event        Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  session      EventSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  registration Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@unique([sessionId, registrationId])
  @@index([sessionId, lastSeenAt])
  @@index([eventId])
  @@index([registrationId])
}

enum RecordingStatus {
  NOT_REQUESTED // cloud recording not enabled for this webinar
  PENDING // webinar ended but recording not yet available
  AVAILABLE // recording fetched and URL stored
  FAILED // fetch attempts exhausted
  EXPIRED // recording fetch window closed (>7 days post-event)
}

enum ZoomMeetingType {
  MEETING
  WEBINAR
  WEBINAR_SERIES
}

enum ZoomMeetingStatus {
  CREATED
  STARTED
  ENDED
  DELETED
}

enum StreamStatus {
  IDLE
  ACTIVE
  ENDED
  ERROR
}

// ==================== PROMO CODES ====================

model PromoCode {
