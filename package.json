{
  "name": "ea-sys",
  "version": "0.4.20",
  "private": true,
  "engines": {
    "node": "24.x",
    "npm": "11.x"
  },
  "scripts": {
    "dev": "next dev -p 3113",
    "build": "prisma generate && next build",
    "postinstall": "prisma generate && node scripts/copy-pdfjs-worker.mjs",
    "start": "next start -p 3113",
    "lint": "eslint",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:seed": "DATABASE_URL=\"$DATABASE_URL_TEST\" DIRECT_URL=\"$DATABASE_URL_TEST\" tsx prisma/seed-e2e.ts",
    "docs:screenshots": "playwright test -c playwright.docs.config.ts",
    "docs:screenshots:ui": "playwright test -c playwright.docs.config.ts --ui",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate deploy",
    "worker:dev": "tsx watch worker/index.ts",
    "worker:start": "tsx worker/index.ts"
  },
