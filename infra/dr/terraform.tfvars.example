# Copy this to terraform.tfvars (gitignored) and fill in real values.

# Required: KMS key ARN for the Singapore DR bucket.
# Get this from the output of `aws kms create-key --region ap-southeast-1 ...`
# during one-time setup (see README.md §1).
dr_kms_key_arn = "arn:aws:kms:ap-southeast-1:CHANGE_ME:key/CHANGE_ME"

# Optional overrides — all have defaults in variables.tf.
# region         = "ap-southeast-1"
# instance_type  = "t3.large"
# git_ref        = "main"
# github_repo    = "meetingmindsexperts/ea-sys"
# dr_bucket_name = "ea-sys-dr-singapore"
