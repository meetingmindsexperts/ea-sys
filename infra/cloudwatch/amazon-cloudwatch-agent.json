{
  "agent": {
    "metrics_collection_interval": 60,
    "run_as_user": "cwagent"
  },
  "metrics": {
    "namespace": "CWAgent",
    "append_dimensions": { "InstanceId": "${aws:InstanceId}" },
    "aggregation_dimensions": [["InstanceId"]],
    "metrics_collected": {
      "disk": {
        "measurement": ["used_percent"],
        "resources": ["/"],
        "drop_device": true,
        "metrics_collection_interval": 60
      },
      "mem": {
        "measurement": ["mem_used_percent"],
        "metrics_collection_interval": 60
      }
    }
  },
  "logs": {
    "logs_collected": {
      "files": {
        "collect_list": [
          {
            "file_path": "/home/ubuntu/ea-sys/logs/app.log",
            "log_group_name": "ea-sys/app",
            "log_stream_name": "mumbai-{instance_id}",
            "retention_in_days": 30,
            "timestamp_format": "%Y-%m-%dT%H:%M:%S",
            "timezone": "UTC"
          },
          {
            "file_path": "/home/ubuntu/ea-sys/logs/error.log",
            "log_group_name": "ea-sys/error",
            "log_stream_name": "mumbai-{instance_id}",
            "retention_in_days": 90,
            "timestamp_format": "%Y-%m-%dT%H:%M:%S",
            "timezone": "UTC"
          }
        ]
      }
    },
    "log_stream_name": "mumbai-fallback",
    "force_flush_interval": 5
  }
}
